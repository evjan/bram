<Component name="AgentEcho">
  <DataSource
    id="agentEchoSrc"
    url="live/AgentEcho.md"
    dataType="text"
    pollIntervalInSeconds="{1}" />

  <VStack gap="$space-4">
    <Card padding="$space-4">
      <VStack gap="$space-3">
        <Heading level="h3">Agent transcript</Heading>
        <Text fontSize="$fontSize-sm">
          This pane renders the live markdown transcript from
          `app/right/live/AgentEcho.md`.
        </Text>
      </VStack>
    </Card>

    <Card padding="$space-4">
      <Markdown content="{agentEchoSrc.value}" breakMode="word" overflowMode="flow" />
    </Card>
  </VStack>
</Component>

<Component name="ConversationPane" var.fullscreenImage="{null}">
  <DataSource id="lastExchange" url="/__last-exchange?t={lastExchangeRefreshTick}" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{window.imageSrcForPath(fullscreenImage)}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack gap="$space-3" padding="$space-3">
    <VStack
      gap="$space-1"
      when="{lastExchange.value &amp;&amp; (lastExchange.value.userText || ((lastExchange.value.userImages || []).length > 0))}"
      var.userImagePreviews="{((lastExchange.value &amp;&amp; lastExchange.value.userImages) || []).length > 0 ? lastExchange.value.userImages : window.__bramExtractImagePaths((lastExchange.value &amp;&amp; lastExchange.value.userText) || '').concat(window.__bramExtractImagePaths((lastExchange.value &amp;&amp; lastExchange.value.iterateFeedback) || ''))}">
        <Text
          fontWeight="$fontWeight-bold"
          color="$color-info-700"
          value="You" />
      <Markdown content="{window.__bramStripImagePaths(window.__bramConversationPaneUserText(lastExchange.value.userText)) + ((lastExchange.value &amp;&amp; lastExchange.value.iterateFeedback) ? '\n\n' + window.__bramStripImagePaths(lastExchange.value.iterateFeedback) : '')}" />
      <VStack
        gap="$space-2"
        when="{userImagePreviews &amp;&amp; userImagePreviews.length > 0}">
        <Items data="{userImagePreviews}">
          <Link onClick="fullscreenImage = $item" noIndicator="true">
            <Image
              src="{window.imageSrcForPath($item)}"
              maxHeight="200px"
              fit="contain" />
          </Link>
        </Items>
      </VStack>
    </VStack>
    <AgentToolUses />
    <AgentLastResponse />
    <Text
      when="{!lastExchange.value || (!lastExchange.value.userText &amp;&amp; !lastExchange.value.assistantText &amp;&amp; (!lastExchange.value.tools || lastExchange.value.tools.length === 0))}"
      fontSize="$fontSize-sm">
      No recent exchange to show.
    </Text>
  </VStack>
</Component>

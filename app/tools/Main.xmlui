<App layout="vertical-sticky" var.rightPaneSize="(measuring…)" var.updateBannerDismissedVersion="{''}" var.setupCompleteProvider="{''}" var.messageBounced="{false}" var.lastSeenAgentVerb="{''}" var.footerVoiceRecording="{false}" var.headerInflightTick="{0}" var.agentSwitcherSelected="{'claude'}" var.agentSwitching="{false}" var.composerFocused="{false}"
  onInit="updateBannerDismissedVersion = readLocalStorage('bram.updateBannerDismissedVersion', ''); startBramLatestJsonlPush(() => (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '')">
  <PushSource
    id="mainAgentStatus"
    initial="{null}"
    subscribe="{window.bramSubscribeAgentStatus()}" />
  <!-- PTY-throughput subscription now lives inside ActivitySparkline so its
       per-chunk churn is isolated from the footer composer. -->

  <PushSource
    id="enhanceStatusEvt"
    initial="{0}"
    subscribe="{window.bramSubscribeEnhanceStatusTick()}" />
  <PushSource
    id="rightPaneSizeEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeRightPaneSize()}" />
  <PushSource
    id="footerVoiceArrival"
    initial="{null}"
    subscribe="{window.bramSubscribeVoiceArrival()}" />
  <PushSource
    id="whisperNotice"
    initial="{null}"
    subscribe="{window.bramSubscribeWhisperUnavailable()}" />
  <PushSource
    id="voiceBusyNotice"
    initial="{null}"
    subscribe="{window.bramSubscribeVoiceBusy()}" />
  <ChangeListener
    listenTo="{whisperNotice.value &amp;&amp; whisperNotice.value.at}"
    onDidChange="(c) => { if (c.newValue) { toast.error('Whisper server is not running and could not be started automatically. Start it manually — see the README Voice input section: https://github.com/judell/bram#voice-input'); } }" />
  <ChangeListener
    listenTo="{voiceBusyNotice.value &amp;&amp; voiceBusyNotice.value.at}"
    onDidChange="(c) => { if (c.newValue) { toast('A voice recording is already in progress. Return to that recording to stop it.'); } }" />
  <ChangeListener
    listenTo="{footerVoiceArrival.value &amp;&amp; footerVoiceArrival.value.at}"
    onDidChange="() => { const ev = footerVoiceArrival.value || null; const t = (ev &amp;&amp; ev.transcript) || ''; const target = (ev &amp;&amp; ev.meta &amp;&amp; ev.meta.target) || ''; if (target === 'message-agent') { if (t &amp;&amp; footerComposerBox) window.__bramAppendVoiceToBox(footerComposerBox, t); footerVoiceRecording = false; worklistVoiceRecordingActive = false; } }" />
  <ChangeListener
    listenTo="{enhanceStatusEvt.value}"
    onDidChange="() => { window.__bramIframeTrace('refetch-called', {context: 'enhance-status-changed'}); enhanceStatus.refetch(); startBramLatestJsonlPush(() => (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || ''); }" />
  <ChangeListener
    listenTo="{rightPaneSizeEvt.value}"
    onDidChange="() => { const s = rightPaneSizeEvt.value || null; rightPaneSize = s ? (s.width + ' × ' + s.height) : '(measuring…)'; }" />
  <DataSource id="enhanceStatus" url="/__enhance/status" />
  <DataSource id="rpInfo" url="/__right-pane-info" />
  <!-- App-scope read of the inflight worklist claim, so the header can show
       "Approving/Iterating/Dropping <item>" even when you've left the Worklist tab. -->
  <DataSource id="headerInflightClaim" url="/__inflight?t={headerInflightTick}" />
  <PushSource
    id="headerInflightEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('inflight-claim-changed')}" />
  <ChangeListener
    listenTo="{headerInflightEvt.value}"
    onDidChange="() => { headerInflightTick = headerInflightTick + 1; window.__bramIframeTrace('refetch-called', {context: 'header-inflight-claim-changed', tick: headerInflightTick}); }" />
  <!-- Backup driver: the dedicated inflight-claim-changed subscription dedups
       against Workspace's, so also refetch whenever the agent status changes
       (App-scope push that's already proven). An in-flight action always makes
       the agent work, so this reliably picks the claim up and drops it. -->
  <ChangeListener
    listenTo="{mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state}"
    onDidChange="() => { headerInflightTick = headerInflightTick + 1; window.__bramIframeTrace('header-inflight-refetch', {tick: headerInflightTick, state: (mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state) || ''}); }" />
  <DataSource id="appInfo" url="/__app-info" />
  <DataSource
    id="headerSettings"
    url="/__settings"
    onLoaded="(v) => window.__bramInitAgentSwitcher(null, settingsAgent(v), agentSwitching, (next) => agentSwitcherSelected = next)" />
  <LocalLinkPreview />
  <!-- Live session meta for the footer echo (mirrors Transcript's source):
       /__sessions/list flags the current session; refetch on changes so the
       footer line tracks the growing live file. -->
  <DataSource
    id="footerSessions"
    url="/__sessions/list"
    queryParams="{{ limit: 20 }}" />
  <PushSource
    id="footerSessionsChangedEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('sessions-list-changed')}" />
  <ChangeListener
    listenTo="{footerSessionsChangedEvt.value &amp;&amp; footerSessionsChangedEvt.value.tick}"
    onDidChange="() => footerSessions.refetch()" />
  <!-- #210 bounce-back: the host emits message-bounced when an agent-pane Esc
       interrupted a just-sent message before the agent committed it (strand).
       Surface a resend banner so a terminal-blind user can recover. -->
  <PushSource
    id="bounceEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('message-bounced')}" />
  <ChangeListener
    listenTo="{bounceEvt.value &amp;&amp; bounceEvt.value.tick}"
    onDidChange="(c) => { if (c.newValue) { messageBounced = true; } }" />
  <!-- Light-touch backstop: the always-mounted footer never re-mounts, so its
       session meta can stay frozen at launch values. Refetch on agent
       turn-state transitions (the App-scope status push already driving the
       header) so date/size land on current values after each turn — no
       polling, ~once per turn. -->
  <ChangeListener
    listenTo="{mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state}"
    onDidChange="() => footerSessions.refetch()" />
  <!-- Footer perf instrument (instrument-footer-composer-rerender): count how
       often the shared footer scope's sources change while the message composer
       is focused, to correlate with heartbeat-batch drift during a typing
       burst. Relocated/removed by the isolate-footer-composer fix. -->
  <ChangeListener
    listenTo="{mainAgentStatus.value}"
    onDidChange="() => __bramTraceFooterChurn('agent-status', composerFocused)" />
  <ChangeListener
    listenTo="{footerSessions.value}"
    onDidChange="() => __bramTraceFooterChurn('session', composerFocused)" />
  <APICall
    id="restartServer"
    url="/__restart-server"
    method="get"
    onSuccess="rpInfo.refetch()" />
  <APICall
    id="runEnhanceSetup"
    url="/__enhance/run"
    method="get"
    onError="setupCompleteProvider = ''; enhanceStatus.refetch()" />
  <ChangeListener
    listenTo="{enhanceStatus.value &amp;&amp; enhanceStatus.value.providerNeedsSetup}"
    onDidChange="(c) => { if (c.newValue) { if ($pathname !== '/') navigate('/'); window.scrollAllToTop(); } }" />
  <ChangeListener
    listenTo="{mainAgentStatus.value &amp;&amp; mainAgentStatus.value.verb}"
    onDidChange="(c) => { if (c.newValue) { lastSeenAgentVerb = c.newValue; } }" />
  <ChangeListener
    listenTo="{((mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state) || '') + '|' + ((mainAgentStatus.value &amp;&amp; mainAgentStatus.value.provider) || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '') + '|' + ((mainAgentStatus.value || enhanceStatus.value) ? '1' : '0')}"
    onDidChange="() => {
      const s = mainAgentStatus.value || {};
      const provider = s.provider || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '';
      const branch = s.state === 'working'
        ? 'working'
        : (s.state === 'finished'
          ? 'finished'
          : ((mainAgentStatus.value || enhanceStatus.value) &amp;&amp; provider ? 'idle-provider' : 'none'));
      if (!window.bramAgentMenu) window.__bramIframeTrace('agent-header-branch', {
        branch,
        state: s.state || '',
        verb: s.verb || '',
        provider,
        source: s.source || '',
        elapsed: s.elapsedText || '',
        lastSeenAgentVerb: lastSeenAgentVerb || ''
      });
    }" />

  <ModalDialog id="setupInfoDialog" title="About agent coordination">
    <VStack gap="$space-3">
      <Text>
        Bram configures this repo so AI agents share a worklist-driven coordination flow. Setup and refresh both install a small, idempotent set of files; rerunning is safe.
      </Text>
      <VStack gap="$space-1">
        <Text fontWeight="bold">What setup and refresh do</Text>
        <Text>• Writes the shared `resources/.worklist-authorization.json` record that every adapter consumes.</Text>
        <Text>• Refreshes the conventions sidecar so Claude and Codex use the current Bram workflow after upgrades.</Text>
        <Text>• Installs the Claude adapter: a `CLAUDE.md` @-import of the conventions sidecar plus worklist-guard and permission-menu hooks.</Text>
        <Text>• Installs the Codex adapter: an `AGENTS.md` block, top-level `developer_instructions`, and worklist-guard plus permission-menu hooks in `~/.codex/config.toml` / `~/.bram`.</Text>
      </VStack>
      <VStack gap="$space-1">
        <Text fontWeight="bold">After setup runs</Text>
        <Text>Later launches of any supported agent in this repo will not prompt again unless the setup artifacts are removed. Additional agent adapters can plug into the same flow in the future.</Text>
      </VStack>
    </VStack>
  </ModalDialog>

  <ModalDialog id="urlInfoDialog" title="Target app info">
    <VStack gap="$space-3">
      <VStack gap="$space-1">
        <Text fontWeight="bold">URL</Text>
        <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm">{rpInfo.value && rpInfo.value.url}</Text>
        <HStack gap="$space-2">
          <Button
            label="Open in browser"
            size="sm"
            onClick="rpInfo.value &amp;&amp; openExternal(rpInfo.value.url)" />
        </HStack>
      </VStack>

      <VStack gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Screen size</Text>
        <Text fontFamily="$fontFamily-monospace" value="{rightPaneSize}" />
      </VStack>

      <VStack when="{appInfo.value}" gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Version</Text>
        <HStack gap="$space-2">
          <Text>current:</Text>
          <Text fontFamily="$fontFamily-monospace">{appInfo.value.current}</Text>
        </HStack>
        <HStack gap="$space-2" when="{appInfo.value.latest}">
          <Text>latest:</Text>
          <Text fontFamily="$fontFamily-monospace">{appInfo.value.latest}</Text>
        </HStack>
        <Text when="{appInfo.value.has_update}" color="$color-warn-600" fontSize="$fontSize-sm">
          A newer release is available.
        </Text>
      </VStack>

      <VStack gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">About Bram</Text>
        <HStack gap="$space-2">
          <Button
            label="README on GitHub"
            size="sm"
            onClick="openExternal('https://github.com/judell/bram/blob/main/README.md')" />
        </HStack>
      </VStack>

      <VStack when="{rpInfo.value &amp;&amp; rpInfo.value.spawned}" gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Project server (.bram.json)</Text>
        <HStack gap="$space-2">
          <Text>command:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.command}</Text>
        </HStack>
        <HStack gap="$space-2" when="{rpInfo.value.spawned.cwd}">
          <Text>cwd:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.cwd}</Text>
        </HStack>
        <HStack gap="$space-2">
          <Text>port:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.port}</Text>
        </HStack>
        <HStack gap="$space-2">
          <Text>path:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.path}</Text>
        </HStack>
        <HStack gap="$space-2" marginTop="$space-1">
          <Button
            label="Restart project server"
            size="sm"
            onClick="restartServer.execute()" />
        </HStack>
      </VStack>

      <VStack
        when="{rpInfo.value &amp;&amp; !rpInfo.value.spawned &amp;&amp; rpInfo.value.url === rpInfo.value.default_right_pane}"
        gap="$space-1"
        marginTop="$space-2">
        <Text fontSize="$fontSize-sm" color="$textColor-secondary">
          No `.bram.json` declared — using the internal loopback default. Legacy `.xmlui-desktop.json` is also supported.
        </Text>
      </VStack>
    </VStack>
  </ModalDialog>

  <HStack
    when="{appInfo.value &amp;&amp; appInfo.value.has_update &amp;&amp; appInfo.value.latest !== updateBannerDismissedVersion}"
    backgroundColor="$color-warn-100"
    padding="$space-2"
    gap="$space-3"
    verticalAlignment="center">
    <Text fontSize="$fontSize-sm">
      Version {appInfo.value.latest} is available. (Current: {appInfo.value.current}.)
    </Text>
    <Button
      label="Download"
      size="xs"
      onClick="appInfo.value.release_url &amp;&amp; openExternal(appInfo.value.release_url)" />
    <SpaceFiller />
    <Button
      label="✕"
      variant="ghost"
      size="xs"
      tooltip="Dismiss — banner returns when a newer version is released"
      onClick="updateBannerDismissedVersion = appInfo.value.latest; writeLocalStorage('bram.updateBannerDismissedVersion', appInfo.value.latest)" />
  </HStack>

  <AppHeader>
    <Theme fontSize-Button="$fontSize-md">
      <HStack gap="$space-0_5" verticalAlignment="center" width="100%">
        <Select
          id="agentSwitcherSelect"
          when="{headerSettings.loaded}"
          width="9rem"
          initialValue="{window.__bramAgentSwitcherInitialProvider(settingsAgent(headerSettings.value))}"
          enabled="{!agentSwitching}"
          inProgress="{agentSwitching}"
          inProgressNotificationMessage="Switching agent"
          tooltip="{agentSwitching ? 'Agent switch in progress' : 'Switch terminal agent'}"
          onDidChange="(next) => window.__bramHandleAgentSwitcherChange(next, agentSwitcherSelected, agentSwitcherSelect, (v) => agentSwitcherSelected = v, (v) => agentSwitching = v, toast)">
          <Option value="claude" label="Claude" />
          <Option value="codex" label="Codex" />
        </Select>
        <SpaceFiller />
        <Text
          when="{headerInflightClaim.value &amp;&amp; headerInflightClaim.value.ids &amp;&amp; headerInflightClaim.value.ids.length > 0}"
          fontStyle="italic"
          color="$color-primary-600"
          overflowMode="none"
          value="{window.__bramInflightBannerLabel(headerInflightClaim.value)}" />
        <SpaceFiller />
        <Theme fontSize-Button="$fontSize-lg">
          <Button
            label="ⓘ"
            variant="ghost"
            tooltip="Show target app info"
            onClick="rpInfo.refetch(); urlInfoDialog.open()" />
        </Theme>
        <Button
          label="A−"
          variant="ghost"
          tooltip="Decrease app font size"
          onClick="window.setAppFontSize(window.getAppFontSize() - 1)" />
        <Button
          label="A+"
          variant="ghost"
          tooltip="Increase app font size"
          onClick="window.setAppFontSize(window.getAppFontSize() + 1)" />
        <Inspector src="{'/__vendor/xs-diff.html?v=' + window.APP_VERSION}" />
      </HStack>
    </Theme>
  </AppHeader>

  <NavPanel>
    <property name="logoTemplate">
      <Fragment/>
    </property>
    <property name="footerTemplate">
      <Fragment/>
    </property>
    <NavLink label="Worklist" to="/worklist" />
    <NavLink label="Transcript" to="/transcript" />
    <NavLink label="Issues" to="/issues" />
    <NavLink label="Commits" to="/commits" />
    <NavLink label="Sessions" to="/sessions" />
    <NavLink label="History" to="/history" />
    <NavLink label="Context" to="/context" />
    <NavLink label="Status" to="/status" />
    <NavLink label="Settings" to="/settings" />
  </NavPanel>

  <VStack
    when="{enhanceStatus.value && enhanceStatus.value.activeProvider && enhanceStatus.value.providerNeedsSetup && !setupCompleteProvider}"
    padding="$space-4"
    gap="$space-3"
    backgroundColor="$color-info-50"
    borderBottom="1px solid $color-info-200">
<HStack verticalAlignment="center" gap="$space-2">
  <Heading level="h3">
    {enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh'
      ? 'Refresh Agent Coordination'
      : 'Set Up Agent Coordination'}
  </Heading>
  <Button
    label="ⓘ"
    variant="ghost"
    size="sm"
    tooltip="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh' ? 'About agent coordination refresh' : 'About agent coordination setup'}"
    onClick="setupInfoDialog.open()" />
</HStack>
<Text
  when="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh'}"
  fontSize="$fontSize-sm">
  Bram was upgraded. Refresh the coordination files so Claude and Codex use the current conventions and hooks.
</Text>
<Text
  when="{!(enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh')}"
  fontSize="$fontSize-sm">
  Install Bram's worklist coordination files and agent adapters for this repo.
</Text>
<HStack>
  <Button
    label="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh' ? 'Refresh Coordination' : 'Run Setup'}"
    onClick="setupCompleteProvider = (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || ''; runEnhanceSetup.execute()" />
</HStack>
  </VStack>

  <HStack
    when="{setupCompleteProvider}"
    backgroundColor="$color-info-100"
    padding="$space-2"
    gap="$space-3"
    verticalAlignment="center">
    <Text fontSize="$fontSize-sm">
      Setup complete. Restart Bram, then start Claude or Codex again in the terminal to pick up the new coordination files.
    </Text>
    <SpaceFiller />
    <Button
      label="✕"
      variant="ghost"
      size="xs"
      tooltip="Dismiss"
      onClick="setupCompleteProvider = ''" />
  </HStack>

  <Theme paddingVertical-Pages="0" paddingVertical-content-App="0">
    <Pages fallbackPath="/worklist">
      <Page url="/"><Workspace activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
      <Page url="/worklist"><Workspace activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
      <Page url="/transcript"><Transcript /></Page>
      <Page url="/status"><Status /></Page>
      <Page url="/settings"><Settings /></Page>
      <Page url="/sessions"><Sessions /></Page>
      <Page url="/history"><History /></Page>
      <Page url="/context"><Context activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
      <Page url="/issues"><Issues /></Page>
      <Page url="/commits"><Commits /></Page>
    </Pages>
  </Theme>
  <Footer>
    <Theme fontSize-TextArea="$fontSize-lg" fontSize-placeholder-TextArea="$fontSize-lg">
    <VStack width="100%" gap="$space-1">
      <HStack verticalAlignment="center" paddingHorizontal="$space-1" paddingBottom="$space-2" gap="$space-0_5">
        <!-- Isolated in its own component so PTY-throughput churn does not
             re-render this footer's message composer. -->
        <ActivitySparkline />
        <!-- Agent-status labels isolated into their own component (own
             agent-status subscription) so the frequent status pushes no longer
             re-render this footer's message composer. The working-verb/spinner
             rationale now lives in FooterAgentStatus.xmlui. Measured by the
             footer-churn / heartbeat-batch instrument. -->
        <FooterAgentStatus enhanceStatus="{enhanceStatus.value}" />
      </HStack>
      <!-- Form exists only for Enter-to-send: TextArea enterSubmits prompts
           the parent Form to submit, and TextArea exposes no standalone Enter
           event. See https://docs.xmlui.org/components/TextArea#entersubmits .
           Enter and the Send button each run the submit block directly. -->
      <Form
        width="100%"
        onSubmit="const m = (footerComposerBox &amp;&amp; footerComposerBox.value || '').trim(); if (m) { messageBounced = false; window.__bramPrepareWorklistMessageSubmission({text: m, voiceTarget: 'message-agent'}); footerComposerBox.setValue(''); }">
        <property name="buttonRowTemplate"><Fragment/></property>
        <HStack width="100%" gap="$space-2" verticalAlignment="center">
          <Button
            label="{footerVoiceRecording ? (worklistVoiceRecordingActive ? '⏹' : '⏳') : '🎤'}"
            variant="ghost"
            size="xs"
            width="2.5rem"
            tooltip="Voice message"
            enabled="{!isWorklistVoiceProcessingTarget('message-agent') &amp;&amp; (!footerVoiceRecording || worklistVoiceRecordingActive)}"
            onClick="setWorklistVoiceTarget('message-agent'); footerVoiceRecording = toggleVoiceForCurrentTarget(footerVoiceRecording)" />
          <TextArea
            id="footerComposerBox"
            placeholder="Message agent: Enter sends, Shift+Enter newline, Ctrl-V/Cmd-V paste screenshot."
            enterSubmits="true"
            autoSize="true"
            minRows="2"
            maxRows="4"
            width="*"
            onGotFocus="setWorklistVoiceTarget('message-agent'); setFocusedFeedbackItemId(''); composerFocused = true"
            onLostFocus="composerFocused = false" />
          <VStack width="8rem" horizontalAlignment="start" itemWidth="fit-content" gap="$space-1">
            <Button
              label="send"
              variant="ghost"
              size="xs"
              tooltip="Send message to agent"
              onClick="const m = (footerComposerBox &amp;&amp; footerComposerBox.value || '').trim(); if (m) { window.__bramPrepareWorklistMessageSubmission({text: m, voiceTarget: 'message-agent'}); footerComposerBox.setValue(''); }" />
            <Button
              label="skip worklist"
              variant="ghost"
              size="xs"
              tooltip="Send message prefixed with skip-worklist:"
              onClick="const m = (footerComposerBox &amp;&amp; footerComposerBox.value || '').trim(); if (m) { window.__bramPrepareWorklistMessageSubmission({text: m, mode: 'skip-worklist', voiceTarget: 'message-agent'}); footerComposerBox.setValue(''); }" />
            <Button
              label="esc"
              variant="ghost"
              size="xs"
              tooltip="Send the Escape key"
              onClick="escToolbarClick()" />
          </VStack>
        </HStack>
      </Form>
      <PastedImageStrip target="message-agent" />
      <Text
        when="{window.__bramSessionMetaLine(window.__bramCurrentSessionOf(footerSessions.value))}"
        fontSize="$fontSize-sm"
        color="$textColor-secondary"
        maxLines="1"
        paddingHorizontal="$space-1"
        value="{window.__bramSessionMetaLine(window.__bramCurrentSessionOf(footerSessions.value))}" />
      <!-- #210 bounce-back resend affordance — in the sticky footer so it's
           always visible. messageBounced is set by the message-bounced event. -->
      <VStack
        when="{messageBounced}"
        padding="$space-2"
        gap="$space-1"
        backgroundColor="$color-info-50"
        borderTop="1px solid $color-info-200">
        <Text fontWeight="bold" fontSize="$fontSize-sm">Last message interrupted before it sent — not delivered.</Text>
        <HStack gap="$space-2" verticalAlignment="center">
          <Button
            label="Resend"
            size="xs"
            tooltip="Submit the message still sitting in the agent's input"
            onClick="messageBounced = false; window.sendKeys('\r')" />
        </HStack>
      </VStack>
    </VStack>
    </Theme>
  </Footer>
</App>

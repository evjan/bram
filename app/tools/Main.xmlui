<App layout="vertical-sticky" var.rightPaneSize="(measuring…)" var.updateBannerDismissedVersion="{''}" var.recording="{false}" var.setupCompleteProvider="{''}"
  onInit="subscribeRightPaneSize((s) => rightPaneSize = s.width + ' × ' + s.height); updateBannerDismissedVersion = readLocalStorage('bram.updateBannerDismissedVersion', ''); subscribeTauriEvent('__bramEnhanceStatusUnlisten', 'enhance-status-changed', () => { enhanceStatus.refetch(); startBramLatestJsonlPolling(() => (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || ''); }); subscribeTauriEvent('__bramMainAgentStatusUnsub', 'agent-status-changed', () => { mainAgentStatus.refetch(); }); subscribeTauriEvent('__bramToolbarPtyMenuUnsub', 'pty-menu-changed', setToolbarPendingMenuFromEvent); startBramLatestJsonlPolling(() => (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '')">
  <DataSource id="enhanceStatus" url="/__enhance/status" />
  <DataSource id="rpInfo" url="/__right-pane-info" />
  <DataSource id="appInfo" url="/__app-info" />
  <DataSource id="mainAgentStatus" url="/__agent-status" pollIntervalInSeconds="1" />
  <ChangeListener
    listenTo="{enhanceStatus.value &amp;&amp; enhanceStatus.value.providerNeedsSetup}"
    onDidChange="(c) => { if (c.newValue) { if ($pathname !== '/') navigate('/'); window.scrollAllToTop(); } }" />

  <ModalDialog id="setupInfoDialog" title="About agent coordination">
    <VStack gap="$space-3">
      <Text>
        Bram configures this repo so AI agents share a worklist-driven coordination flow. Setup and refresh both install a small, idempotent set of files; rerunning is safe.
      </Text>
      <VStack gap="$space-1">
        <Text fontWeight="bold">What setup and refresh do</Text>
        <Text>• Writes the shared `resources/.worklist-authorization.json` record that every adapter consumes.</Text>
        <Text>• Refreshes the conventions sidecar so Claude and Codex use the current Bram workflow after upgrades.</Text>
        <Text>• Installs the Claude adapter: a `CLAUDE.md` @-import of the conventions sidecar plus `.claude/hooks/worklist-guard.py` (PreToolUse).</Text>
        <Text>• Installs the Codex adapter: an `AGENTS.md` block teaching Codex the worklist flow plus a `~/.codex/config.toml` PreToolUse hook.</Text>
      </VStack>
      <VStack gap="$space-1">
        <Text fontWeight="bold">After setup runs</Text>
        <Text>Later launches of any supported agent in this repo will not prompt again unless the setup artifacts are removed. Additional agent adapters can plug into the same flow in the future.</Text>
      </VStack>
    </VStack>
  </ModalDialog>

  <ModalDialog id="urlInfoDialog" title="Target app info">
    <VStack gap="$space-3">
      <VStack gap="$space-1">
        <Text fontWeight="bold">URL</Text>
        <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm">{rpInfo.value && rpInfo.value.url}</Text>
        <HStack gap="$space-2">
          <Button
            label="Open in browser"
            size="sm"
            onClick="rpInfo.value &amp;&amp; openExternal(rpInfo.value.url)" />
        </HStack>
      </VStack>

      <VStack gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Screen size</Text>
        <Text fontFamily="$fontFamily-monospace" value="{rightPaneSize}" />
      </VStack>

      <VStack when="{appInfo.value}" gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Version</Text>
        <HStack gap="$space-2">
          <Text>current:</Text>
          <Text fontFamily="$fontFamily-monospace">{appInfo.value.current}</Text>
        </HStack>
        <HStack gap="$space-2" when="{appInfo.value.latest}">
          <Text>latest:</Text>
          <Text fontFamily="$fontFamily-monospace">{appInfo.value.latest}</Text>
        </HStack>
        <Text when="{appInfo.value.has_update}" color="$color-warn-600" fontSize="$fontSize-sm">
          A newer release is available.
        </Text>
      </VStack>

      <VStack gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">About Bram</Text>
        <HStack gap="$space-2">
          <Button
            label="README on GitHub"
            size="sm"
            onClick="openExternal('https://github.com/judell/bram/blob/main/README.md')" />
        </HStack>
      </VStack>

      <VStack when="{rpInfo.value &amp;&amp; rpInfo.value.spawned}" gap="$space-1" marginTop="$space-2">
        <Text fontWeight="bold">Project server (.bram.json)</Text>
        <HStack gap="$space-2">
          <Text>command:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.command}</Text>
        </HStack>
        <HStack gap="$space-2" when="{rpInfo.value.spawned.cwd}">
          <Text>cwd:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.cwd}</Text>
        </HStack>
        <HStack gap="$space-2">
          <Text>port:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.port}</Text>
        </HStack>
        <HStack gap="$space-2">
          <Text>path:</Text>
          <Text fontFamily="$fontFamily-monospace">{rpInfo.value.spawned.path}</Text>
        </HStack>
        <HStack gap="$space-2" marginTop="$space-1">
          <Button
            label="Restart project server"
            size="sm"
            onClick="window.fetch('/__restart-server').then((r) => { if (r.ok) rpInfo.refetch(); })" />
        </HStack>
      </VStack>

      <VStack
        when="{rpInfo.value &amp;&amp; !rpInfo.value.spawned &amp;&amp; rpInfo.value.url === rpInfo.value.default_right_pane}"
        gap="$space-1"
        marginTop="$space-2">
        <Text fontSize="$fontSize-sm" color="$textColor-secondary">
          No `.bram.json` declared — using the internal loopback default. Legacy `.xmlui-desktop.json` is also supported.
        </Text>
      </VStack>
    </VStack>
  </ModalDialog>

  <HStack
    when="{appInfo.value &amp;&amp; appInfo.value.has_update &amp;&amp; appInfo.value.latest !== updateBannerDismissedVersion}"
    backgroundColor="$color-warn-100"
    padding="$space-2"
    gap="$space-3"
    verticalAlignment="center">
    <Text fontSize="$fontSize-sm">
      Version {appInfo.value.latest} is available. (Current: {appInfo.value.current}.)
    </Text>
    <Button
      label="Download"
      size="xs"
      onClick="appInfo.value.release_url &amp;&amp; openExternal(appInfo.value.release_url)" />
    <SpaceFiller />
    <Button
      label="✕"
      variant="ghost"
      size="xs"
      tooltip="Dismiss — banner returns when a newer version is released"
      onClick="updateBannerDismissedVersion = appInfo.value.latest; writeLocalStorage('bram.updateBannerDismissedVersion', appInfo.value.latest)" />
  </HStack>

  <AppHeader>
    <Theme fontSize-Button="$fontSize-md">
      <HStack gap="$space-0_5" verticalAlignment="center" width="100%">
        <HStack width="14rem" minWidth="14rem" verticalAlignment="center" paddingHorizontal="$space-2">
          <Text
            when="{(mainAgentStatus.value || enhanceStatus.value) &amp;&amp; !(mainAgentStatus.value &amp;&amp; (mainAgentStatus.value.state === 'working' || mainAgentStatus.value.state === 'finished')) &amp;&amp; ((mainAgentStatus.value &amp;&amp; mainAgentStatus.value.provider) || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider))}"
            fontSize="$fontSize-sm"
            fontStyle="italic"
            color="$textColor-secondary"
            overflowMode="none"
            value="{(((mainAgentStatus.value &amp;&amp; mainAgentStatus.value.provider) || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider)) === 'claude' ? 'claude code' : ((mainAgentStatus.value &amp;&amp; mainAgentStatus.value.provider) || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || ''))}" />
          <HStack
            when="{mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state === 'working'}"
            gap="$space-1"
            verticalAlignment="center">
            <Theme size-Spinner="0.85em">
              <Spinner />
            </Theme>
            <Text
              fontSize="$fontSize-sm"
              fontStyle="italic"
              overflowMode="none"
              value="{(mainAgentStatus.value.provider === 'claude' ? 'claude code' : (mainAgentStatus.value.provider || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '')) + ' ' + (mainAgentStatus.value.verb || 'working') + '…'}" />
            <Text
              fontSize="$fontSize-sm"
              color="$textColor-secondary"
              overflowMode="none"
              value="{mainAgentStatus.value.elapsedText || ''}" />
          </HStack>
          <HStack
            when="{mainAgentStatus.value &amp;&amp; mainAgentStatus.value.state === 'finished'}"
            gap="$space-1"
            verticalAlignment="center">
            <Text
              fontSize="$fontSize-sm"
              fontStyle="italic"
              color="$textColor-secondary"
              overflowMode="none"
              value="{(mainAgentStatus.value.provider === 'claude' ? 'claude code' : (mainAgentStatus.value.provider || (enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider) || '')) + ' ' + (mainAgentStatus.value.verb || 'Finished') + (mainAgentStatus.value.elapsedText ? ' · ' + mainAgentStatus.value.elapsedText : '')}" />
          </HStack>
        </HStack>
        <Stack width="4rem" minWidth="4rem" />
        <Theme fontSize-Button="$fontSize-lg">
          <Button
            label="ⓘ"
            variant="ghost"
            tooltip="Show target app info"
            onClick="rpInfo.refetch(); urlInfoDialog.open()" />
        </Theme>
        <Button
          label="A−"
          variant="ghost"
          tooltip="Decrease app font size"
          onClick="window.setAppFontSize(window.getAppFontSize() - 1)" />
        <Button
          label="A+"
          variant="ghost"
          tooltip="Increase app font size"
          onClick="window.setAppFontSize(window.getAppFontSize() + 1)" />
        <Button
          label="{recording ? '⏹ stop' : '🎤 voice'}"
          variant="ghost"
          tooltip="Voice input — focused Worklist boxes receive text; otherwise sends to terminal"
          onClick="recording = toggleVoiceForCurrentTarget(recording)" />
        <Button
          label="1"
          variant="ghost"
          tooltip="Permission menu: send keystroke 1"
          onClick="traceToolbarKey('1'); sendKeys('1\r')" />
        <Button
          label="2"
          variant="ghost"
          tooltip="Permission menu: send keystroke 2"
          onClick="traceToolbarKey('2'); sendKeys('2\r')" />
        <Button
          label="3"
          variant="ghost"
          tooltip="Permission menu: send keystroke 3"
          onClick="traceToolbarKey('3'); sendKeys('3\r')" />
        <Button
          label="Yes"
          variant="ghost"
          tooltip="Send 'yes' as a user turn"
          onClick="traceToolbarKey('yes'); toTurn('yes')" />
        <Button
          label="No"
          variant="ghost"
          tooltip="Send 'no' as a user turn"
          onClick="traceToolbarKey('no'); toTurn('no')" />
        <Button
          label="Esc"
          variant="ghost"
          tooltip="Send Esc to interrupt"
          onClick="traceToolbarKey('esc'); sendKeys('\x1b')" />
        <Inspector src="{'/__vendor/xs-diff.html?v=' + window.APP_VERSION}" />
        <SpaceFiller />
      </HStack>
    </Theme>
  </AppHeader>

  <NavPanel>
    <property name="logoTemplate">
      <Fragment/>
    </property>
    <NavLink label="Worklist" to="/worklist" />
    <NavLink label="Issues" to="/issues" />
    <NavLink label="Commits" to="/commits" />
    <NavLink label="Sessions" to="/sessions" />
    <NavLink label="History" to="/history" />
    <NavLink label="Feedback" to="/feedback" />
    <NavLink label="Context" to="/context" />
    <NavLink label="Status" to="/status" />
    <NavLink label="Settings" to="/settings" />
  </NavPanel>

  <VStack
    when="{enhanceStatus.value && enhanceStatus.value.activeProvider && enhanceStatus.value.providerNeedsSetup}"
    padding="$space-4"
    gap="$space-3"
    backgroundColor="$color-info-50"
    borderBottom="1px solid $color-info-200">
<HStack verticalAlignment="center" gap="$space-2">
  <Heading level="h3">
    {enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh'
      ? 'Refresh Agent Coordination'
      : 'Set Up Agent Coordination'}
  </Heading>
  <Button
    label="ⓘ"
    variant="ghost"
    size="sm"
    tooltip="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh' ? 'About agent coordination refresh' : 'About agent coordination setup'}"
    onClick="setupInfoDialog.open()" />
</HStack>
<Text
  when="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh'}"
  fontSize="$fontSize-sm">
  Bram was upgraded. Refresh the coordination files so Claude and Codex use the current conventions and hooks.
</Text>
<Text
  when="{!(enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh')}"
  fontSize="$fontSize-sm">
  Install Bram's worklist coordination files and agent adapters for this repo.
</Text>
<HStack>
  <Button
    label="{enhanceStatus.value && enhanceStatus.value.providerSetupKind === 'codex-hook-refresh' ? 'Refresh Coordination' : 'Run Setup'}"
    onClick="setupCompleteProvider = enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider; window.fetch('/__enhance/run').then(() => enhanceStatus.refetch()).catch(() => { setupCompleteProvider = ''; enhanceStatus.refetch(); })" />
</HStack>
  </VStack>

  <HStack
    when="{setupCompleteProvider}"
    backgroundColor="$color-info-100"
    padding="$space-2"
    gap="$space-3"
    verticalAlignment="center">
    <Text fontSize="$fontSize-sm">
      {setupCompleteProvider === 'claude'
        ? 'Setup complete. Restart Claude to pick up the new hook.'
        : 'Setup complete. Codex picks up the new config on its next turn — no restart needed.'}
    </Text>
    <SpaceFiller />
    <Button
      label="✕"
      variant="ghost"
      size="xs"
      tooltip="Dismiss"
      onClick="setupCompleteProvider = ''" />
  </HStack>

  <VStack
    when="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider === 'codex' &amp;&amp; enhanceStatus.value.codexHookCurrent &amp;&amp; !enhanceStatus.value.codexTrustAck}"
    padding="$space-4"
    gap="$space-3"
    backgroundColor="$color-info-50"
    borderBottom="1px solid $color-info-200">
    <Heading level="h3">Codex will ask you to trust a hook</Heading>
    <Markdown content="- Codex prompts you to **trust** `codex-worklist-guard.py` the first time it runs after the script is installed.
- Trust it — that's the local hook that enforces the worklist gate on Codex's side.
- Dismissed without trusting? Worklist enforcement falls back to the watcher-revert path: commits that bypass the gate are caught after the fact, but not blocked at write time.
- This is a **first-install primer**, not an ongoing safety net. The notice returns automatically if the hook is reinstalled or its contents change, but Bram can't see when you revoke Codex's trust directly. If you do that, restart Codex — and delete `~/.bram/codex-trust-ack` if you want this notice back." />
    <HStack>
      <Button
        label="Got it"
        onClick="window.fetch('/__enhance/codex-trust-ack').then(() => enhanceStatus.refetch())" />
    </HStack>
  </VStack>

  <Pages fallbackPath="/">
    <Page url="/"><Transcript activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
    <Page url="/worklist"><Workspace activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
    <Page url="/status"><Status /></Page>
    <Page url="/settings"><Settings /></Page>
    <Page url="/sessions"><Sessions /></Page>
    <Page url="/history"><History /></Page>
    <Page url="/feedback"><Feedback /></Page>
    <Page url="/context"><Context activeProvider="{enhanceStatus.value &amp;&amp; enhanceStatus.value.activeProvider}" /></Page>
    <Page url="/issues"><Issues /></Page>
    <Page url="/commits"><Commits /></Page>
  </Pages>
</App>

<Component name="ConversationPane" var.fullscreenImage="{null}" var.heldExchange="{null}">
  <!-- Sources the exchange from Workspace's conversationStateDS
       (/__conversation-state) via $props.exchange. That route's URL carries a
       cache-buster (?t={tick}) that increments on every refetch, so its
       .value oscillates blank<->content continuously during a turn (confirmed:
       textLen 0 <-> N on each refetch). Binding the pane straight to it both
       flashes and corrupts the dim.

       FIX: render the whole pane from heldExchange -- a state var that a
       ChangeListener updates ONLY when $props.exchange is *meaningful* (has
       userText / assistantText / tools). It therefore never holds a blank, so
       the pane never blanks and never flashes, while real content (including
       incremental growth) still flows through. A ChangeListener (not a var
       binding) is used so the update is reliably reactive.

       DIM: derived downstream from heldExchange.assistantText -- empty means a
       new turn has started and you're looking at the prior response (held in
       AgentLastResponse.heldAssistantText), so it dims; non-empty means the
       fresh response has begun, so it brightens and stays bright.

       ChangeListener does not fire on initial mount
       (https://docs.xmlui.org/howto/debounce-with-changelistener). -->
  <ChangeListener
    listenTo="{(($props.exchange &amp;&amp; $props.exchange.userText) || '') + '|' + window.assistantOutputSignature($props.exchange) + '|' + (($props.exchange &amp;&amp; $props.exchange.tools &amp;&amp; $props.exchange.tools.length) || 0)}"
    onDidChange="() => { if ($props.exchange &amp;&amp; ($props.exchange.userText || $props.exchange.assistantText || ($props.exchange.tools &amp;&amp; $props.exchange.tools.length))) { heldExchange = $props.exchange; } }" />
  <ChangeListener
    listenTo="{window.assistantOutputSignature(heldExchange) + '|' + ((heldExchange &amp;&amp; heldExchange.tools &amp;&amp; heldExchange.tools.length) || 0)}"
    onDidChange="() => {
      const text = (heldExchange &amp;&amp; heldExchange.assistantText) || '';
      window.__bramIframeTrace('conversation-value-changed', {assistantSig: window.assistantOutputSignature(heldExchange), assistantTextLen: text.length, toolsLen: (heldExchange &amp;&amp; heldExchange.tools &amp;&amp; heldExchange.tools.length) || 0, hasAssistant: !!text});
    }" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{window.imageSrcForPath(fullscreenImage)}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack gap="$space-3" padding="$space-3">
    <VStack
      gap="$space-1"
      when="{heldExchange &amp;&amp; (heldExchange.userText || ((heldExchange.userImages || []).length > 0))}"
      var.userImagePreviews="{((heldExchange &amp;&amp; heldExchange.userImages) || []).length > 0 ? heldExchange.userImages : window.__bramExtractImagePaths((heldExchange &amp;&amp; heldExchange.userText) || '').concat(window.__bramExtractImagePaths((heldExchange &amp;&amp; heldExchange.iterateFeedback) || ''))}">
        <Text
          fontWeight="$fontWeight-bold"
          color="$color-info-700"
          value="You" />
      <Markdown content="{window.__bramStripImagePaths(window.__bramConversationPaneUserText(heldExchange.userText)) + ((heldExchange &amp;&amp; heldExchange.iterateFeedback) ? '\n\n' + window.__bramStripImagePaths(heldExchange.iterateFeedback) : '')}" />
      <VStack
        gap="$space-2"
        when="{userImagePreviews &amp;&amp; userImagePreviews.length > 0}">
        <Items data="{userImagePreviews}">
          <Link onClick="fullscreenImage = $item" noIndicator="true">
            <Image
              src="{window.imageSrcForPath($item)}"
              maxHeight="200px"
              fit="contain" />
          </Link>
        </Items>
      </VStack>
    </VStack>
    <AgentToolUses
      exchange="{heldExchange}"
      active="{heldExchange &amp;&amp; conversationActive(heldExchange)}" />
    <AgentLastResponse
      exchange="{heldExchange}"
      active="{heldExchange &amp;&amp; conversationActive(heldExchange)}" />
    <Text
      when="{!heldExchange || (!heldExchange.userText &amp;&amp; !heldExchange.assistantText &amp;&amp; (!heldExchange.tools || heldExchange.tools.length === 0))}"
      fontSize="$fontSize-sm">
      No recent exchange to show.
    </Text>
  </VStack>
</Component>

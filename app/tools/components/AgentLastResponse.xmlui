<Component name="AgentLastResponse" var.fullscreenImage="{null}" var.heldAssistantText="{''}">
  <!-- Data arrives via $props.exchange (the held-bridged display exchange from
       ConversationPane); no own fetch.

       Dim semantics: dimmed === you are looking at the PREVIOUS response while
       awaiting the next one. The cue is simply whether the current exchange has
       fresh assistant text yet:
       - no current assistantText (a new turn has started) => show the last
         response from heldAssistantText, DIMMED.
       - current assistantText present (the new response has begun) => show it at
         full opacity, and keep it bright as it accumulates and after it
         finishes -- until the next user message empties assistantText and
         re-dims it. No 'working' signal involved. See last-turn-sync.

       heldAssistantText holds the last non-empty response so the dim window has
       something to show (the prior response) before fresh text streams in.
       (Because $props.exchange is the held-bridged value, a transient refetch
       blank keeps the prior exchange and stays bright -- no dim flicker.)

       ChangeListener does not fire on initial mount
       (https://docs.xmlui.org/howto/debounce-with-changelistener). -->
  <ChangeListener
    listenToSources="{{exchange: $props.exchange}}"
    onDidChange="() => { const txt = ($props.exchange &amp;&amp; $props.exchange.assistantText) || ''; if (txt) { heldAssistantText = txt; } }" />
  <ChangeListener
    listenTo="{!!($props.exchange &amp;&amp; $props.exchange.assistantText)}"
    onDidChange="(c) => window.__bramIframeTrace('conversation-fade', {stage: c.newValue ? 'fade-in' : 'dim', trigger: 'response-text', hasText: !!c.newValue})" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{window.imageSrcForPath(fullscreenImage)}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack
    gap="$space-1"
    opacity="{($props.exchange &amp;&amp; $props.exchange.assistantText) ? 1 : 0.55}"
    transition="opacity 560ms ease-out"
    when="{$props.active}">
    <Text
      fontWeight="$fontWeight-bold"
      color="$color-success-700"
      value="Agent: Last response" />
    <Markdown content="{window.__bramStripImagePaths(($props.exchange &amp;&amp; $props.exchange.assistantText) || heldAssistantText)}" />
    <VStack
      gap="$space-2"
      when="{$props.exchange &amp;&amp; $props.exchange.assistantImages &amp;&amp; $props.exchange.assistantImages.length > 0}">
      <Items data="{$props.exchange.assistantImages}">
        <Link onClick="fullscreenImage = $item" noIndicator="true">
          <Image
            src="{window.imageSrcForPath($item)}"
            maxHeight="200px"
            fit="contain" />
        </Link>
      </Items>
    </VStack>
  </VStack>
</Component>

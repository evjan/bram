<Component name="Transcript"
  var.fullscreenImage="{null}">
  <!-- Bounded List as the sole scroller. The List gets height="*" inside a
       height="100%" parent, so it fills the remaining viewport and scrolls
       within its OWN virtua container (footer stays docked, page does not
       grow) -- the star-fill-through-Page pattern proven by Workspace's
       HSplitter height="*". A bounded List is required for the new native
       scroll event to fire: in the prior unbounded Items/page-scroll layout
       the PAGE scrolled, so the List reported nothing.

       Follow + read-pause are driven explicitly from the List's `scroll`
       event (no DOM access, no opaque scrollAnchor heuristic): onScroll
       tracks atBottom; when new events arrive, follow only if the user is
       parked at the bottom. The event fires only for user-driven scrolls
       (the List's own scrollToBottom is guarded), so following never fights
       reading. -->
  <External
    id="jsonlEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeLatestJsonl()}" />
  <External
    id="agentMenuEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeAgentMenu()}" />
  <!-- Session metadata for the header: /__sessions/list flags the live
       session with current:true and carries title/mtime/size. Auto-detects
       the provider when none is passed (see list_sessions). Refetched on
       sessions-list-changed so the size/date track the growing live file. -->
  <DataSource
    id="transcriptSessions"
    url="/__sessions/list"
    queryParams="{{ limit: 20 }}" />
  <External
    id="transcriptSessionsChangedEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('sessions-list-changed')}" />
  <ChangeListener
    listenTo="{transcriptSessionsChangedEvt.value &amp;&amp; transcriptSessionsChangedEvt.value.tick}"
    onDidChange="() => transcriptSessions.refetch()" />
  <!-- { feedbackRef: text } map so iterate turns (whose feedback rides a
       feedbackRef, not inline) can show their feedback. Refetched when a draft
       is written or promoted to history. -->
  <DataSource id="feedbackMap" url="/__feedback/map" />
  <External
    id="feedbackDraftsChangedEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('feedback-drafts-changed')}" />
  <External
    id="feedbackHistoryChangedEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('feedback-history-changed')}" />
  <ChangeListener
    listenTo="{feedbackDraftsChangedEvt.value &amp;&amp; feedbackDraftsChangedEvt.value.tick}"
    onDidChange="() => feedbackMap.refetch()" />
  <ChangeListener
    listenTo="{feedbackHistoryChangedEvt.value &amp;&amp; feedbackHistoryChangedEvt.value.tick}"
    onDidChange="() => feedbackMap.refetch()" />
  <Theme maxWidth-ModalDialog="95vw">
    <ModalDialog
      when="{!!fullscreenImage}"
      onClose="fullscreenImage = null">
      <Image
        src="{window.imageSrcForPath(fullscreenImage)}"
        fit="contain"
        width="100%"
        height="80vh" />
    </ModalDialog>
  </Theme>
  <VStack
    height="100%"
    padding="$space-4"
    gap="$space-2"
    onInit="window.__bramSetTranscriptMounted(true)"
    onCleanup="window.__bramSetTranscriptMounted(false)"
    var.events="{window.__bramTranscriptEventsWithMenu(jsonlEvt.value, agentMenuEvt.value)}"
    var.expanded="{[]}"
    var.atBottom="{true}"
    var.currentSession="{((transcriptSessions.value || []).find(s => s.current)) || ((transcriptSessions.value || [])[0])}">
    <HStack verticalAlignment="center" gap="$space-2">
      <Heading level="h2">Transcript</Heading>
      <Text fontSize="$fontSize-sm" color="$textColor-secondary" value="{events.length + ' events'}" />
    </HStack>
    <Text
      when="{currentSession}"
      fontSize="$fontSize-sm"
      maxLines="1"
      value="{window.__bramSessionMetaLine(currentSession)}" />
    <Text
      when="{events.length === 0}"
      color="$textColor-secondary"
      value="No transcript yet." />
    <List
      id="transcriptList"
      height="*"
      data="{events}"
      onScroll="(ev) => atBottom = ev.atEnd">
      <property name="emptyListTemplate"><Fragment/></property>
      <VStack gap="$space-1" paddingVertical="$space-1">
        <!-- user message -->
        <VStack
          when="{$item.kind === 'user'}"
          backgroundColor="$color-surface-100"
          padding="$space-2"
          borderRadius="$borderRadius"
          gap="$space-1">
          <Text value="You" fontWeight="bold" color="$color-primary-600" fontSize="$fontSize-sm" />
          <Markdown content="{window.__bramFormatUserTurn($item.text, feedbackMap.value)}" />
        </VStack>
        <!-- assistant text -->
        <Markdown
          when="{$item.kind === 'text'}"
          content="{window.__bramStripImagePaths($item.text)}" />
        <!-- image strip -->
        <VStack
          when="{$item.kind === 'images'}"
          gap="$space-2"
          paddingVertical="$space-1">
          <Items data="{$item.images || []}">
            <Link onClick="fullscreenImage = $item" noIndicator="true">
              <Image
                src="{window.imageSrcForPath($item)}"
                maxHeight="220px"
                fit="contain" />
            </Link>
          </Items>
        </VStack>
        <!-- thinking (foldable) -->
        <VStack when="{$item.kind === 'thinking'}" gap="$space-0_5">
          <Link noIndicator="true" onClick="expanded = window.__bramToggleInArray(expanded, $item.id)">
            <Text
              fontSize="$fontSize-sm"
              fontStyle="italic"
              color="$textColor-secondary"
              value="{((expanded || []).includes($item.id) ? '▾' : '▸') + '  💭 thinking'}" />
          </Link>
          <VStack
            when="{(expanded || []).includes($item.id)}"
            backgroundColor="$color-surface-50"
            padding="$space-2"
            borderRadius="$borderRadius">
            <Markdown content="{$item.text}" />
          </VStack>
        </VStack>
        <!-- tool call (foldable) -->
        <VStack when="{$item.kind === 'tool'}" gap="$space-0_5">
          <Link noIndicator="true" onClick="expanded = window.__bramToggleInArray(expanded, $item.id)">
            <HStack gap="$space-1" verticalAlignment="center">
              <Text fontSize="$fontSize-sm" fontWeight="bold" value="{((expanded || []).includes($item.id) ? '▾' : '▸') + '  🔧 ' + $item.name}" />
              <Text fontSize="$fontSize-sm" color="$textColor-secondary" value="{$item.summary}" />
            </HStack>
          </Link>
          <VStack
            when="{(expanded || []).includes($item.id)}"
            gap="$space-1"
            backgroundColor="$color-surface-50"
            padding="$space-2"
            borderRadius="$borderRadius">
            <Markdown
              when="{$item.commandDisplay || $item.summary}"
              overflowMode="scroll"
              content="{window.__bramFormatToolCommand($item.commandDisplay || $item.summary)}" />
            <!-- Tool result: typed Markdown code-fence when the formatter
                 helper is live (after a rebuild), else the prior raw Text so a
                 hot-reload never blanks or markdown-mangles the expansion.
                 Errors always use the red raw Text. -->
            <Markdown
              when="{$item.result &amp;&amp; !$item.isError &amp;&amp; window.__bramFormatToolResult}"
              overflowMode="scroll"
              content="{window.__bramFormatToolResult($item.result, $item.name, $item.summary)}" />
            <Text
              when="{$item.result &amp;&amp; ($item.isError || !window.__bramFormatToolResult)}"
              fontFamily="$fontFamily-monospace"
              fontSize="$fontSize-xs"
              color="{$item.isError ? '$color-danger-600' : '$textColor-secondary'}"
              value="{$item.result}" />
          </VStack>
        </VStack>
        <!-- provisional in-flight prose (grid-sourced), shown above the pending
             menu until the real assistant record lands in the JSONL. Rendered
             identically to a settled assistant message so the swap is seamless;
             the content-presence guard in __bramTranscriptEventsWithMenu drops
             it once the real record renders. -->
        <Markdown
          when="{$item.kind === 'menu-prose'}"
          content="{window.__bramStripImagePaths($item.text)}" />
        <!-- pending agent menu, interleaved at its natural (latest) position -->
        <AgentMenuView when="{$item.kind === 'menu'}" menu="{$item.menu}" surface="transcript" />
      </VStack>
    </List>
    <!-- Explicit follow-bottom (replaces scrollAnchor="bottom" and its
         content-wrapper re-stick ResizeObserver, xmlui #3599). onScroll keeps
         atBottom in sync (fires only on user scrolls; programmatic scrolls are
         guarded), and we re-pin to the end on new content only while the user
         is parked there — so following never fights reading, and there's no
         RO-driven re-stick to loop or yank the viewport. -->
    <ChangeListener
      listenTo="{events.length}"
      onDidChange="atBottom ? transcriptList.scrollToBottom() : null" />
  </VStack>
</Component>

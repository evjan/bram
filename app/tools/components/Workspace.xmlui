<Component
  name="Workspace"
  var.submittedItemId="{null}"
  var.submitting="{false}"
  var.expandedItemIds="{window.__bramRestoreWorklistUiState('expandedItemIds')}"
  var.feedbackDraftsById="{window.__bramRestoreWorklistUiState('feedbackDraftsById')}"
  var.lastWorklistSig="{''}"
  var.closeIssuesDialog="{null}"
  var.closeIssuesItemRef="{null}"
  var.closeIssuesState="{null}"
  var.newItemHelp="{false}"
  var.newItemSubmitting="{false}"
  var.newItemStartSig="{''}"
  var.newItemTurnEnded="{false}"
  var.newItemIssue="{null}"
  var.newItemVoiceRecording="{false}"
  var.openToolId="{null}"
  var.openTool="{null}"
  var.inflightTick="{0}"
  var.actionProgressTick="{0}"
  var.actionProgressKind="{''}"
  var.actionProgressScope="{''}"
  var.worklistTurnsTick="{0}"
  var.submittedWorklistImages="{[]}"
  var.messageSubmitResult="{null}"
  var.worklistActionResult="{null}"
  var.messageSentAtText="{''}"
  var.awaitingResponse="{window.__bramRestoreWorklistAwaiting()}"
  var.awaitingResponseSetAt="{window.__bramRestoreWorklistAwaitingSetAt()}"
  var.agentTurnEndedSinceSubmit="{false}"
  var.fullscreenImage="{null}"
  var.messageVoiceRecording="{false}"
  var.feedbackVoiceRecording="{false}"
  var.feedbackVoiceRecordingItemId="{''}"
  var.pendingPastedImageCount="{window.__bramPasteStateSnapshot ? window.__bramPasteStateSnapshot().count : 0}"
  var.pendingPastedImagePaths="{window.__bramPasteStateSnapshot ? window.__bramPasteStateSnapshot().paths : []}"
  var.stagingPastedImageCount="{window.__bramPasteStateSnapshot ? window.__bramPasteStateSnapshot().staging : 0}"
  var.submittedWorklistMessage="{window.__bramRestoreWorklistSubmittedMessage()}"
  var.sessionSubmittedWorklistMessage="{window.__bramRestoreWorklistSessionSubmittedMessage ? window.__bramRestoreWorklistSessionSubmittedMessage() : ''}"
  var.submittedTurnsBaseline="{window.__bramRestoreWorklistSubmittedBaseline()}"
  var.submittedKind="{window.__bramRestoreWorklistSubmittedKind()}"
  var.agentDockLaunchResponseDim="{window.__bramShouldDimAgentDockOnMount ? window.__bramShouldDimAgentDockOnMount() : true}"
  var.agentDockLaunchResponseText="{''}"
  var.agentDockLaunchUserText="{''}">
  <DataSource
    id="worklist"
    url="/__worklist"
    onLoaded="(data) => {
      const items = (data && data.items) || [];
      const sigForTrace = items
        .filter(i => i && i.id)
        .map(i => i.id + ':' + (i.status || 'proposed'))
        .sort()
        .join(',');
      window.__bramIframeTrace('onLoaded-entered', {sig: sigForTrace, items: items.length});
      // Inflight-clear paths previously living here (item-gone,
      // stale-timeout) moved to inflightClaim's onLoaded.
      // The host-managed sentinel is the authoritative spinner signal
      // (no localStorage involvement); this onLoaded just tracks
      // selection state.
      const currentSig = items.filter(i => i && i.id).map(i => i.id + ':' + (i.status || 'proposed')).sort().join(',');
      const transientEmpty = lastWorklistSig && !currentSig;
      if (!transientEmpty) {
        const existingIds = new Set(items.map(i => i && i.id).filter(Boolean));
        const prevExpanded = expandedItemIds || [];
        const filteredExpanded = prevExpanded.filter(id => existingIds.has(id));
        if (filteredExpanded.length !== prevExpanded.length) {
          expandedItemIds = filteredExpanded;
          const prevDrafts = feedbackDraftsById || {};
          const nextDrafts = {};
          for (const id of filteredExpanded) {
            if (prevDrafts[id]) nextDrafts[id] = prevDrafts[id];
          }
          feedbackDraftsById = nextDrafts;
          window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds, feedbackDraftsById: feedbackDraftsById});
        }
      }
      if (newItemSubmitting && currentSig !== newItemStartSig) {
        window.__bramIframeTrace('new-item-clear', {via: 'sig-change', prevSig: newItemStartSig, currentSig: currentSig});
        newItemSubmitting = false;
        newItemStartSig = '';
        newItemTurnEnded = false;
      } else if (newItemSubmitting && newItemTurnEnded) {
        window.__bramIframeTrace('new-item-clear', {via: 'turn-end', prevSig: newItemStartSig, currentSig: currentSig});
        newItemSubmitting = false;
        newItemStartSig = '';
        newItemTurnEnded = false;
      }
      if (currentSig) lastWorklistSig = currentSig;
    }" />
  <!-- #182 incident 1 investigation. Fires on every worklist value-shape
       transition (loaded / isRefetching / value-presence / item-count),
       not just the loaded event. If the trace shows value briefly
       transitioning through undefined or items.length through 0 during
       a refetch where the host payload was unchanged, the flicker is
       iframe-side and the gate at line 376 should switch from
       when="{worklist.value}" to when="{worklist.loaded}". If the trace
       shows the host returning a transient empty payload, the fix is
       host-side (atomic read in /__worklist). -->
  <ChangeListener
    listenToSources="{{value: worklist.value, loaded: worklist.loaded, isRefetching: worklist.isRefetching}}"
    onDidChange="(c) => window.__bramIframeTrace('worklist-value-transition', {
      prev: c.prevValue,
      next: c.newValue,
      loaded: worklist.loaded,
      isRefetching: worklist.isRefetching,
      hasValue: !!worklist.value,
      itemsLength: (worklist.value &amp;&amp; worklist.value.items || []).length
    })" />
  <DataSource
    id="worklistConfig"
    url="/__worklist-config" />
  <DataSource
    id="openIssues"
    url="/__issues"
    when="{newItemHelp}" />
  <DataSource
    id="gitStatus"
    url="/__git/status" />
  <DataSource
    id="commits"
    url="/__commits"
    when="{closeIssuesDialog !== null}" />
  <!-- Sentinel-derived inflight consumer (#84 item 3). The host writes
       resources/.inflight-claim.json on /__worklist/resolve (approved
       / drop) and /__iterate/begin. Approved/drop sentinels clear at
       host silence-detected turn-end, with /__worklist/end available
       as an explicit endpoint; iterate sentinels clear via
       /__iterate/end. Each write/clear emits
       inflightTick below and forces this DataSource to refetch. When
       the sentinel no longer claims the targeted item, the onLoaded
       handler clears localStorage and resets per-cycle state.
       Replaces the prior heuristic clear paths (agent-turn-end
       listener, quietDebounce Timer, JSONL agent-idle, item-gone,
       60 s stale-timeout). -->
  <DataSource
    id="inflightClaim"
    url="/__inflight?t={inflightTick}"
    onLoaded="(data) => {
      const u = window.__bramInflightSentinelDecide(data, submitting, submittedItemId);
      if (u.kind === 'submit') {
        submitting = u.submitting;
        submittedItemId = u.submittedItemId;
        actionProgressKind = u.actionProgressKind || actionProgressKind || '';
      } else if (u.kind === 'clear') {
        window.__bramIframeTrace('inflight-clear', u.trace);
        const completedId = submittedItemId;
        if (completedId && feedbackDraftsById && feedbackDraftsById[completedId]) {
          const nextDrafts = Object.assign({}, feedbackDraftsById);
          delete nextDrafts[completedId];
          feedbackDraftsById = nextDrafts;
          window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById});
        }
        submitting = false;
        if (window.__bramMarkTurnEnded('inflight-clear', {awaitingResponse: awaitingResponse, submitting: submitting, awaitingResponseSetAt: awaitingResponseSetAt, submittedKind: submittedKind})) {
          awaitingResponse = false;
          submittedKind = null;
          window.__bramClearWorklistAwaiting(false);
        }
        submittedItemId = null;
        submittedKind = null;
        window.__bramSetWorklistSubmittedKind(null);
        actionProgressKind = '';
        actionProgressScope = '';
        actionProgressTick = 0;
        setWorklistVoiceTarget('message-agent');
      }
    }" />
  <!-- Reactive voice-target reset: when no item is expanded, reset
       worklistVoiceTarget to 'message-agent' so the always-mounted
       ChangeListener can deliver transcripts. -->
  <ChangeListener
    listenTo="{(expandedItemIds || []).length === 0 ? 'none' : 'some'}"
    onDidChange="() => { if ((expandedItemIds || []).length === 0 && worklistVoiceTarget === 'feedback') setWorklistVoiceTarget('message-agent'); }" />
  <!-- Worklist still consumes conversation-derived currentTurnEdits for
       in-flight edit hints. Transcript owns the chat surface. -->
  <PushSource
    id="conversationStateDS"
    initial="{null}"
    subscribe="{window.bramSubscribeConversationState()}" />
  <ChangeListener
    listenToSources="{{
      assistantText: conversationStateDS.value &amp;&amp; conversationStateDS.value.lastAssistantText &amp;&amp; conversationStateDS.value.lastAssistantText.text,
      exchangeUserText: conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; conversationStateDS.value.lastExchange.userText,
      exchangeAssistantText: conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; conversationStateDS.value.lastExchange.assistantText
    }}"
    onDidChange="(c) => {
      const v = c.newValue || {};
      const t = v.assistantText || '';
      if (!t) return;
      const userText = v.exchangeUserText || '';
      const exchangeAnswered = !!v.exchangeAssistantText;
      const answeredThisSessionSubmission = !!(exchangeAnswered &amp;&amp; userText &amp;&amp; sessionSubmittedWorklistMessage &amp;&amp; userText === sessionSubmittedWorklistMessage);
      if (!agentDockLaunchResponseText) {
        agentDockLaunchResponseText = t;
        agentDockLaunchUserText = userText;
        if (answeredThisSessionSubmission) {
          agentDockLaunchResponseDim = false;
        }
        return;
      }
      if (t !== agentDockLaunchResponseText || answeredThisSessionSubmission || (exchangeAnswered &amp;&amp; userText &amp;&amp; userText !== agentDockLaunchUserText)) {
        agentDockLaunchResponseDim = false;
        agentDockLaunchResponseText = t;
      }
    }" />
  <!-- Pending permission menu, same push the Transcript and NavPanel use, so
       the Worklist-page dock can answer a menu without switching tabs. -->
  <PushSource
    id="agentMenuEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeAgentMenu()}" />
  <!-- The dock's "You" turn arrives fully resolved from the host: the
       conversation-state payload runs the same projection pass as /__turns
       (worklist payloads, feedback refs, turn frames), so no client-side
       feedback map or payload formatting is needed. -->

  <!-- Drives the in-flight "Approving./.../..." dot cycle below the
       targeted item. 2 s tick is intentionally slow - action cycles can
       take minutes, and a fast cycle is distracting at that scale. -->
  <Timer
    initialDelay="0"
    interval="2000"
    enabled="{submitting &amp;&amp; actionProgressKind}"
    onTick="actionProgressTick = actionProgressTick + 1" />
  <ChangeListener
    listenTo="{awaitingResponse}"
    onDidChange="(c) => { if (c.newValue &amp;&amp; !c.prevValue) { agentTurnEndedSinceSubmit = false; } }" />
  <ChangeListener
    listenTo="{messageSubmitResult &amp;&amp; messageSubmitResult.seq}"
    onDidChange="() => { const r = messageSubmitResult || {}; if (!r.submitted) return; pendingPastedImageCount = r.pendingPastedImageCount; pendingPastedImagePaths = r.pendingPastedImagePaths; stagingPastedImageCount = r.stagingPastedImageCount; submittedWorklistImages = r.submittedWorklistImages; submittedWorklistMessage = r.submittedWorklistMessage; submittedTurnsBaseline = r.submittedTurnsBaseline; messageSentAtText = r.messageSentAtText; submittedKind = r.submittedKind; awaitingResponse = r.awaitingResponse; awaitingResponseSetAt = r.awaitingResponseSetAt; }" />
  <ChangeListener
    listenTo="{worklistActionResult &amp;&amp; worklistActionResult.seq}"
    onDidChange="() => { const r = worklistActionResult || {}; if (!r.submittedKind) return; submittedWorklistImages = r.submittedWorklistImages; submittedWorklistMessage = r.submittedWorklistMessage; submittedTurnsBaseline = r.submittedTurnsBaseline; messageSentAtText = r.messageSentAtText; awaitingResponse = r.awaitingResponse; awaitingResponseSetAt = r.awaitingResponseSetAt; pendingPastedImageCount = r.pendingPastedImageCount; pendingPastedImagePaths = r.pendingPastedImagePaths; stagingPastedImageCount = r.stagingPastedImageCount; submittedItemId = r.submittedItemId; submittedKind = r.submittedKind; submitting = r.submitting; actionProgressScope = r.actionProgressScope || 'item'; actionProgressKind = r.actionProgressKind; actionProgressTick = r.actionProgressTick; const nextDrafts = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = nextDrafts; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); }" />
  <DataSource
    id="worklistToolDetailDS"
    url="/__tool-detail?id={openToolId || ''}"
    when="{!!openToolId}" />
  <!-- Lightweight latest-state DataSources follow talk-session changes
       during streaming. Full session turns are larger and refresh on
       turn boundaries via worklistTurnsTick. -->
  <!-- The form clears on submit; the submitted text is shown below as
       the persisted "You" half of the local exchange. awaitingResponse
       is memory-only display state; it never locks typing and never
       restores from localStorage after iframe reload. -->

  <VStack
    paddingTop="0"
    paddingHorizontal="$space-6"
    paddingBottom="$space-10"
    gap="$space-6"
    onInit="">
    <Theme
      maxWidth-ModalDialog="50vw"
      backgroundColor-ModalDialog="$color-surface-50"
      backgroundColor-overlay-ModalDialog="rgba(15, 23, 42, 0.42)"
      borderRadius-ModalDialog="$borderRadius-lg"
      padding-ModalDialog="$space-6"
      fontSize-title-ModalDialog="$fontSize-xl"
      fontWeight-title-ModalDialog="$fontWeight-bold"
      textColor-title-ModalDialog="$color-primary-700"
      marginBottom-title-ModalDialog="$space-4">
    <ModalDialog
      when="{!!openToolId}"
      onClose="openTool = null; openToolId = null"
      title="Tool"
      var.openDetail="{worklistToolDetailDS.value}"
      var.modalInput="{openDetail &amp;&amp; openDetail.input}"
      var.modalResult="{openDetail &amp;&amp; openDetail.result}">
      <VStack gap="$space-2">
        <Text
          when="{openTool &amp;&amp; openTool.summary}"
          fontFamily="$fontFamily-monospace"
          fontSize="$fontSize-sm"
          color="$textColor-secondary"
          value="{openTool.summary}" />
        <VStack
          when="{openTool &amp;&amp; openTool.name === 'Write' &amp;&amp; modalInput &amp;&amp; modalInput.content}"
          gap="{0}"
          padding="$space-3"
          border="1px solid $color-surface-200"
          borderRadius="$borderRadius"
          backgroundColor="$backgroundColor-primary">
          <Text
            fontSize="$fontSize-xs"
            fontWeight="$fontWeight-bold"
            color="$textColor-secondary"
            paddingHorizontal="$space-2"
            value="{modalInput.file_path || 'Content'}" />
          <Markdown content="{modalInput.content}" />
        </VStack>
        <VStack
          when="{!(openTool &amp;&amp; openTool.name === 'Write' &amp;&amp; modalInput &amp;&amp; modalInput.content)}"
          gap="{0}"
          padding="$space-3"
          border="1px solid $color-surface-200"
          borderRadius="$borderRadius"
          backgroundColor="$backgroundColor-primary"
          var.inputBody="{window.__bramToolInputJsonLines(modalInput, 200)}">
          <Text
            fontSize="$fontSize-xs"
            fontWeight="$fontWeight-bold"
            color="$textColor-secondary"
            paddingHorizontal="$space-2"
            value="Input" />
          <Items data="{inputBody.lines}">
            <Text
              fontFamily="$fontFamily-monospace"
              fontSize="$fontSize-sm"
              whiteSpace="pre-wrap"
              paddingHorizontal="$space-2"
              value="{$item}" />
          </Items>
          <Text
            when="{inputBody.remaining > 0}"
            fontSize="$fontSize-xs"
            color="$textColor-secondary"
            paddingHorizontal="$space-2"
            value="{inputBody.remaining + ' more line' + (inputBody.remaining === 1 ? '' : 's') + '…'}" />
        </VStack>
        <VStack
          when="{modalResult &amp;&amp; modalResult.lines.length > 0}"
          gap="{0}"
          padding="$space-3"
          border="1px solid $color-surface-200"
          borderRadius="$borderRadius"
          backgroundColor="$backgroundColor-primary">
          <Text
            fontSize="$fontSize-xs"
            fontWeight="$fontWeight-bold"
            color="$textColor-secondary"
            paddingHorizontal="$space-2"
            value="Result" />
          <Items data="{modalResult.lines}">
            <Text
              fontFamily="$fontFamily-monospace"
              fontSize="$fontSize-sm"
              whiteSpace="pre-wrap"
              paddingHorizontal="$space-2"
              color="{openTool &amp;&amp; openTool.errored ? '$color-danger-700' : ''}"
              value="{$item}" />
          </Items>
          <Text
            when="{modalResult.remaining > 0}"
            fontSize="$fontSize-xs"
            color="$textColor-secondary"
            paddingHorizontal="$space-2"
            value="{modalResult.remaining + ' more line' + (modalResult.remaining === 1 ? '' : 's') + '…'}" />
        </VStack>
      </VStack>
    </ModalDialog>
    </Theme>

    <ModalDialog
      when="{!!fullscreenImage}"
      fullScreen="true"
      onClose="fullscreenImage = null">
      <Image
        src="{window.imageSrcForPath(fullscreenImage)}"
        fit="contain"
        width="100%"
        height="100%" />
    </ModalDialog>

    <VStack height="100%" gap="0" paddingTop="0">
      <!-- Form.persist restores unsent text across iframe reloads; TextArea.enterSubmits lets Enter submit the parent Form. -->
      <PushSource
        id="talkSessionEvt"
        initial="{null}"
        subscribe="{window.bramSubscribeTalkSessionChange()}" />
      <ChangeListener
        listenTo="{talkSessionEvt.value &amp;&amp; talkSessionEvt.value.at}"
        onDidChange="() => {
          const ev = talkSessionEvt.value || null;
          const correlationId = (ev &amp;&amp; ev.correlationId) || '';
          const atHostMs = (ev &amp;&amp; ev.atHostMs) || 0;
          window.__bramIframeTrace('listener-fired', {context: 'talk-session-changed', correlation_id: correlationId, at_host_ms: atHostMs, delta_to_emit_ms: atHostMs ? (Date.now() - atHostMs) : -1});
          // conversation-state now arrives via the conversationStateDS PushSource
          // push (conversation-state-changed); no refetch needed here.
        }" />
      <PushSource
        id="voiceArrival"
        initial="{null}"
        subscribe="{window.bramSubscribeVoiceArrival()}" />
      <ChangeListener
        listenTo="{voiceArrival.value &amp;&amp; voiceArrival.value.at}"
        onDidChange="() => { const ev = voiceArrival.value || null; const t = (ev &amp;&amp; ev.transcript) || ''; const target = (ev &amp;&amp; ev.meta &amp;&amp; ev.meta.target) || ''; if (target === 'message-agent') { if (t &amp;&amp; worklistInputBox) window.__bramAppendVoiceToBox(worklistInputBox, t); messageVoiceRecording = false; worklistVoiceRecordingActive = false; } }" />
    <VStack gap="0" width="100%" height="*">
      <!-- Top composer hidden (not removed) — the App Footer composer replaces it. Flip when back to show. -->
      <HStack when="{false}" horizontalAlignment="center" width="100%" marginBottom="$space-6">
        <!-- Message-agent composer, inlined from the former MessageComposer
             component so the mic toggle runs in Workspace scope. As a separate
             component the mic could only signal across the boundary via
             emitEvent, which the engine deferred by ~30s; inline, its onClick
             flips messageVoiceRecording directly. The Form exists only for
             Enter-to-send: TextArea enterSubmits prompts the parent Form to
             submit, and TextArea exposes no standalone Enter event. See
             https://docs.xmlui.org/components/TextArea#entersubmits .
             Draft survival uses the window helpers; the Form persist was
             removed because it wrote bram.worklistMessageDraftForm while
             restore reads bram.worklistMessageDraft, so it never round-tripped.
             Enter and the Send button each run the submit block directly. -->
        <Form
          width="90%"
          data="{{ message: window.__bramRestoreWorklistDraft() }}"
          onWillSubmit="(data) => { if (!worklistInputBox || !worklistInputBox.value || !worklistInputBox.value.trim()) return false; }"
          onSubmit="const r = window.__bramPrepareWorklistMessageSubmission({text: (worklistInputBox &amp;&amp; worklistInputBox.value) || '', voiceTarget: worklistVoiceTarget || 'message-agent'}); messageSubmitResult = r; if (r.submitted) { if (worklistInputBox) worklistInputBox.setValue(''); window.__bramClearWorklistDraft(); }">
          <property name="buttonRowTemplate"><Fragment/></property>
          <HStack gap="$space-2" verticalAlignment="center" width="100%">
            <Button
              label="{messageVoiceRecording ? (worklistVoiceRecordingActive ? '⏹' : '⏳') : '🎤'}"
              variant="ghost"
              size="xs"
              width="2.5rem"
              tooltip="Voice message"
              enabled="{!(submitting || awaitingResponse) &amp;&amp; !isWorklistVoiceProcessingTarget('message-agent') &amp;&amp; (!messageVoiceRecording || worklistVoiceRecordingActive)}"
              onClick="window.__bramIframeTrace('voice-trace', {stage: 'mic-direct'}); setWorklistVoiceTarget('message-agent'); messageVoiceRecording = toggleVoiceForCurrentTarget(messageVoiceRecording)" />
            <TextArea
              id="worklistInputBox"
              initialValue="{window.__bramRestoreWorklistDraft()}"
              enterSubmits="true"
              autoComplete="off"
              autoCorrect="{false}"
              spellCheck="{false}"
              autoCapitalize="off"
              onGotFocus="setWorklistVoiceTarget('message-agent'); setFocusedFeedbackItemId(''); window.__bramIframeTrace('paste-image-target', {stage: 'message-focus', target: 'message-agent'})"
              onDidChange="(v) => { window.__bramPersistWorklistDraft(v); }"
              enabled="{!(submitting || awaitingResponse)}"
              placeholder="Message agent: Enter sends, Shift+Enter newline, Ctrl-V/Cmd-V paste screenshot."
              autoSize="true"
              minRows="1"
              maxRows="6"
              width="*" />
            <VStack width="8rem" horizontalAlignment="start" itemWidth="fit-content" gap="$space-1">
              <Button
                label="send"
                variant="ghost"
                size="xs"
                tooltip="Send this message to the agent (Enter also sends)."
                enabled="{!(submitting || awaitingResponse) &amp;&amp; ((worklistInputBox &amp;&amp; worklistInputBox.value || '').trim().length > 0)}"
                onClick="const msg = (worklistInputBox &amp;&amp; worklistInputBox.value || '').trim(); if (msg) { const r = window.__bramPrepareWorklistMessageSubmission({text: msg, voiceTarget: worklistVoiceTarget || 'message-agent'}); messageSubmitResult = r; if (r.submitted) { if (worklistInputBox) worklistInputBox.setValue(''); window.__bramClearWorklistDraft(); } }" />
              <Button
                label="skip worklist"
                variant="ghost"
                size="xs"
                tooltip="Send and bypass propose-first for this turn — edit files directly. Use when you want a direct edit."
                enabled="{!(submitting || awaitingResponse) &amp;&amp; ((worklistInputBox &amp;&amp; worklistInputBox.value || '').trim().length > 0)}"
                onClick="const raw = (worklistInputBox &amp;&amp; worklistInputBox.value || '').trim(); if (raw) { const r = window.__bramPrepareWorklistMessageSubmission({text: raw, mode: 'skip-worklist', voiceTarget: worklistVoiceTarget || 'message-agent'}); messageSubmitResult = r; if (r.submitted) { if (worklistInputBox) worklistInputBox.setValue(''); window.__bramClearWorklistDraft(); } }" />
            </VStack>
            <Theme size-Spinner="14px">
              <Spinner when="{isWorklistVoiceProcessingTarget('message-agent')}" />
            </Theme>
          </HStack>
          <PastedImageStrip target="message-agent" />
        </Form>
      </HStack>

      <VStack
        gap="$space-3"
        overflowY="auto">
    <VStack gap="$space-3" when="{worklist.value}">
      <VStack gap="$space-3">
        <HStack gap="$space-3" verticalAlignment="center">
          <Heading level="h2">Worklist</Heading>
          <Button
            label="+ New item"
            size="xs"
            enabled="{!newItemSubmitting}"
            onClick="newItemHelp = true" />
          <Theme size-Spinner="16px">
            <Spinner when="{newItemSubmitting}" />
          </Theme>
          <SpaceFiller />
        </HStack>
        <VStack
          when="{worklist.value.exists && worklist.value.schemaError}"
          gap="$space-2"
          padding="$space-3"
          backgroundColor="$color-warning-50"
          borderRadius="$borderRadius">
          <Text
            fontWeight="$fontWeight-bold"
            color="$color-warning-700"
            value="Worklist file has an invalid root shape" />
          <Text
            color="$textColor-primary"
            value="{worklist.value.schemaErrorMessage || 'resources/worklist.json must be a JSON object with description and items at the root.'}" />
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            value="{worklist.value.path}" />
          <Text value="Expected shape:" />
          <VStack
            gap="0"
            padding="$space-2"
            backgroundColor="$color-surface-50"
            borderRadius="$borderRadius">
            <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm" value='{' />
            <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm" value='  "description": "",' />
            <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm" value='  "items": []' />
            <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-sm" value='}' />
          </VStack>
        </VStack>
        <Text
          when="{worklist.value.exists && !worklist.value.schemaError && (!worklist.value.items || worklist.value.items.length === 0)}"
          color="$textColor-secondary">
          (none)
        </Text>
        <HStack
          when="{worklistConfig.value && worklistConfig.value.batchCommitActions && worklist.value.items && window.__bramCountByStatus(worklist.value.items, 'applied') >= 2}"
          gap="$space-2"
          verticalAlignment="center"
          padding="$space-2"
          borderRadius="$borderRadius"
          backgroundColor="$color-surface-50">
          <Text
            fontSize="$fontSize-sm"
            color="$textColor-secondary"
            value="{window.__bramCountByStatus(worklist.value.items, 'applied') + ' items ready to commit'}" />
          <Button
            label="{'Approve all (' + window.__bramCountByStatus(worklist.value.items, 'applied') + ')'}"
            size="xs"
            enabled="{!submitting}"
            onClick="const r = window.__bramPrepareBatchWorklistActionSubmission({kind: 'approved', items: worklist.value.items}); expandedItemIds = r.expandedItemIds; feedbackDraftsById = r.feedbackDraftsById; submitting = r.submitting; actionProgressScope = r.actionProgressScope; actionProgressKind = r.actionProgressKind; actionProgressTick = r.actionProgressTick; submittedItemId = r.submittedItemId; submittedKind = r.submittedKind; toTurn(r.turnText)" />
          <Button
            label="{'Drop all (' + window.__bramCountByStatus(worklist.value.items, 'applied') + ')'}"
            size="xs"
            variant="outlined"
            enabled="{!submitting}"
            onClick="const r = window.__bramPrepareBatchWorklistActionSubmission({kind: 'drop', items: worklist.value.items}); expandedItemIds = r.expandedItemIds; feedbackDraftsById = r.feedbackDraftsById; submitting = r.submitting; actionProgressScope = r.actionProgressScope; actionProgressKind = r.actionProgressKind; actionProgressTick = r.actionProgressTick; submittedItemId = r.submittedItemId; submittedKind = r.submittedKind; toTurn(r.turnText)" />
        </HStack>
        <HStack
          when="{submitting &amp;&amp; actionProgressScope === 'batch' &amp;&amp; actionProgressKind}"
          gap="$space-2"
          verticalAlignment="center"
          paddingHorizontal="$space-2"
          paddingBottom="$space-2"
          backgroundColor="$color-surface-50">
          <Theme size-Spinner="14px">
            <Spinner />
          </Theme>
          <Text
            fontSize="$fontSize-sm"
            fontStyle="italic"
            color="$textColor-secondary"
            value="{window.__bramInflightActionLabel(actionProgressKind) + '.'.repeat(1 + (actionProgressTick % 3))}" />
        </HStack>
        <Items data="{worklist.value.items}">
          <VStack gap="$space-1">
            <HStack gap="$space-3" verticalAlignment="start">
              <HStack width="1.75em" horizontalAlignment="center" verticalAlignment="center">
                <Theme size-Spinner="14px">
                  <Spinner when="{submitting &amp;&amp; actionProgressScope !== 'batch' &amp;&amp; submittedItemId === $item.id}" />
                </Theme>
                <Button
                  when="{!(submitting &amp;&amp; actionProgressScope !== 'batch' &amp;&amp; submittedItemId === $item.id)}"
                  label="{(expandedItemIds || []).includes($item.id) ? '▼' : '▶'}"
                  variant="ghost"
                  size="xs"
                  enabled="{!(submitting &amp;&amp; actionProgressScope !== 'batch' &amp;&amp; submittedItemId === $item.id)}"
                  tooltip="{(expandedItemIds || []).includes($item.id) ? 'Close item' : 'Open item'}"
                  onClick="expandedItemIds = (expandedItemIds || []).includes($item.id) ? (expandedItemIds || []).filter(i => i !== $item.id) : ((expandedItemIds || []).concat([$item.id])); window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds, feedbackDraftsById: feedbackDraftsById || {}})" />
              </HStack>
              <VStack gap="$space-1" width="*">
                <HStack gap="$space-2" verticalAlignment="center">
                  <Theme paddingHorizontal-Button-xs="$space-0_5">
                    <HStack gap="$space-0_5" verticalAlignment="center">
                      <!-- status badge + ⓘ — hug per howto/control-item-spacing-with-gap -->
                      <Text
                        value="{($item.status || 'proposed') === 'applied' ? 'TO COMMIT' : (($item.status || 'proposed') === 'proposed' ? 'TO APPLY' : 'INVALID STATUS: ' + ($item.status || ''))}"
                        fontSize="$fontSize-xs"
                        fontWeight="$fontWeight-bold"
                        color="{($item.status || 'proposed') === 'applied' ? '$color-success-600' : (($item.status || 'proposed') === 'proposed' ? '$color-info-600' : '$color-danger-700')}" />
                      <Button
                        when="{$itemIndex === worklist.value.items.findIndex(i => (i.status || 'proposed') === ($item.status || 'proposed'))}"
                        label="ⓘ"
                        variant="ghost"
                        size="xs"
                        tooltip="{($item.status || 'proposed') === 'applied' || ($item.status || 'proposed') === 'proposed' ? 'What does this badge mean?' : 'Why is this status invalid?'}"
                        onClick="($item.status || 'proposed') === 'applied' ? statusAppliedHelpDialog.open() : (($item.status || 'proposed') === 'proposed' ? statusProposedHelpDialog.open() : statusInvalidHelpDialog.open())" />
                    </HStack>
                  </Theme>
                  <Text value="{$item.id}" fontWeight="$fontWeight-bold" />
                </HStack>
                <!-- In-flight feedback panel: shows files touched in the
                     agent's current turn while a cycle targets this
                     item. Reads from conversationStateDS.currentTurnEdits
                     (host-side derivation backed by the shared parse cache);
                     replaces the iframe currentTurnEdits walk that had
                     started timing out on busy turns. -->
                <VStack
                  when="{submitting && actionProgressScope !== 'batch' && submittedItemId === $item.id}"
                  gap="$space-0_5"
                  paddingLeft="$space-3"
                  var.turnEdits="{(conversationStateDS.value &amp;&amp; conversationStateDS.value.currentTurnEdits) || []}">
                  <Text
                    when="{turnEdits.length > 0}"
                    fontSize="$fontSize-xs"
                    color="$textColor-secondary"
                    value="Editing" />
                  <Items data="{turnEdits.slice(0, 5)}">
                    <Text
                      fontSize="$fontSize-xs"
                      variant="code"
                      value="{$item.filePath}" />
                  </Items>
                  <Text
                    when="{turnEdits.length > 5}"
                    fontSize="$fontSize-xs"
                    color="$textColor-secondary"
                    value="{'+ ' + (turnEdits.length - 5) + ' more'}" />
                </VStack>
                <HStack
                  when="{(expandedItemIds || []).includes($item.id)}"
                  gap="$space-2"
                  verticalAlignment="center">
                  <Button
                    label="{feedbackVoiceRecording &amp;&amp; feedbackVoiceRecordingItemId === $item.id ? (worklistVoiceRecordingActive ? '⏹' : '⏳') : '🎤'}"
                    variant="ghost"
                    size="xs"
                    tooltip="Voice feedback"
                    enabled="{!submitting &amp;&amp; !isWorklistVoiceProcessingTarget('feedback') &amp;&amp; (!feedbackVoiceRecording || (feedbackVoiceRecordingItemId === $item.id &amp;&amp; worklistVoiceRecordingActive))}"
                    onClick="setWorklistVoiceTarget('feedback:' + $item.id); if (!feedbackVoiceRecording) feedbackVoiceRecordingItemId = $item.id; feedbackVoiceRecording = toggleVoiceForCurrentTarget(feedbackVoiceRecording)" />
                  <TextArea
                    id="feedbackBox"
                    initialValue="{(feedbackDraftsById || {})[$item.id] || ''}"
                    placeholder="Message to agent"
                    autoComplete="off"
                    autoCorrect="{false}"
                    spellCheck="{false}"
                    autoCapitalize="off"
                    onGotFocus="setWorklistVoiceTarget('feedback'); setFocusedFeedbackItemId($item.id); window.__bramIframeTrace('paste-image-target', {stage: 'feedback-focus', target: 'feedback:' + $item.id, item: $item.id})"
                    onLostFocus="() => { const next = Object.assign({}, feedbackDraftsById || {}); next[$item.id] = feedbackBox.value || ''; feedbackDraftsById = next; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); }"
                    resize="vertical"
                    minRows="2"
                    maxRows="16"
                    width="*"
                    fontSize="$fontSize-sm"
                    enabled="{!(submitting &amp;&amp; submittedItemId === $item.id)}" />
                  <ChangeListener
                    listenTo="{voiceArrival.value &amp;&amp; voiceArrival.value.at}"
                    onDidChange="() => { const ev = voiceArrival.value || null; const t = (ev &amp;&amp; ev.transcript) || ''; const target = (ev &amp;&amp; ev.meta &amp;&amp; ev.meta.target) || ''; if (target === ('feedback:' + $item.id)) { if (t) { const newValue = window.__bramAppendVoiceToBox(feedbackBox, t); if (newValue !== false) { const draftsNext = Object.assign({}, feedbackDraftsById || {}); draftsNext[$item.id] = newValue; feedbackDraftsById = draftsNext; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); } } feedbackVoiceRecording = false; feedbackVoiceRecordingItemId = ''; worklistVoiceRecordingActive = false; } }" />
                  <ChangeListener
                    listenTo="{awaitingResponse}"
                    onDidChange="(c) => { if (!c.newValue &amp;&amp; c.prevValue &amp;&amp; submittedItemId === $item.id) { const next = Object.assign({}, feedbackDraftsById || {}); delete next[$item.id]; feedbackDraftsById = next; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); } }" />
                  <Theme size-Spinner="14px">
                    <Spinner when="{isWorklistVoiceProcessingTarget('feedback:' + $item.id)}" />
                  </Theme>
                  <Button
                    label="ⓘ"
                    variant="ghost"
                    size="xs"
                    tooltip="What does the feedback do?"
                    onClick="($item.status || 'proposed') === 'applied' ? feedbackAppliedHelpDialog.open() : feedbackProposedHelpDialog.open()" />
                </HStack>
                <HStack
                  when="{(expandedItemIds || []).includes($item.id)}"
                  gap="$space-3"
                  verticalAlignment="center">
                  <HStack gap="$space-1" verticalAlignment="center">
                    <Button
                      label="Approve"
                      size="xs"
                      enabled="{!submitting && (($item.status || 'proposed') === 'applied' || ($item.status || 'proposed') === 'proposed')}"
                      onClick="(() => { window.__bramIframeTrace('click', {target: 'approve', item: $item.id}); if ($item.status === 'applied' &amp;&amp; $item.closesIssues &amp;&amp; $item.closesIssues.length > 0) { closeIssuesItemRef = $item; closeIssuesState = initCloseIssueState($item.closesIssues); closeIssuesDialog = $item.id; return; } const sentText = (feedbackBox &amp;&amp; feedbackBox.value) || (feedbackDraftsById || {})[$item.id] || ''; const r = window.__bramPrepareWorklistActionSubmission({kind: 'approved', items: worklist.value.items, selectedId: $item.id, rawFeedback: sentText, feedbackDraftsById: feedbackDraftsById || {}, expandedItemIds: expandedItemIds || [], voiceTarget: worklistVoiceTarget || 'message-agent', inflightTarget: 'approve'}); const next = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = next; if (feedbackBox) feedbackBox.setValue(''); window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); worklistActionResult = r; toTurn(r.turnText); })()" />
                    <Theme paddingHorizontal-Button-xs="$space-0_5">
                      <Button
                        label="ⓘ"
                        variant="ghost"
                        size="xs"
                        tooltip="What does Approve do?"
                        onClick="approveHelpDialog.open()" />
                    </Theme>
                  </HStack>
                  <HStack gap="$space-1" verticalAlignment="center">
                    <Button
                      label="Iterate"
                      size="xs"
                      enabled="{!submitting && (($item.status || 'proposed') === 'applied' || ($item.status || 'proposed') === 'proposed') && (((feedbackBox &amp;&amp; feedbackBox.value) || (feedbackDraftsById || {})[$item.id] || '').trim().length > 0 || (window.__bramPasteStateSnapshot ? window.__bramPasteStateSnapshot('feedback:' + $item.id).count : pendingPastedImageCount) > 0)}"
                      onClick="window.__bramIframeTrace('click', {target: 'iterate', item: $item.id, pasteTarget: 'feedback:' + $item.id}); const sentText = (feedbackBox &amp;&amp; feedbackBox.value) || (feedbackDraftsById || {})[$item.id] || ''; const r = window.__bramPrepareWorklistActionSubmission({kind: 'iterate', items: worklist.value.items, selectedId: $item.id, rawFeedback: sentText, feedbackDraftsById: feedbackDraftsById || {}, expandedItemIds: expandedItemIds || [], voiceTarget: worklistVoiceTarget || 'message-agent', inflightTarget: 'iterate'}); const next = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = next; if (feedbackBox) feedbackBox.setValue(''); window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); worklistActionResult = r; sendIterateWithFeedbackDraft(worklist.value.items, $item.id, r.feedback)" />
                    <Theme paddingHorizontal-Button-xs="$space-0_5">
                      <Button
                        label="ⓘ"
                        variant="ghost"
                        size="xs"
                        tooltip="What does Iterate do?"
                        onClick="iterateHelpDialog.open()" />
                    </Theme>
                  </HStack>
                  <HStack gap="$space-1" verticalAlignment="center">
                    <Button
                      label="Drop"
                      size="xs"
                      enabled="{!submitting}"
                      onClick="window.__bramIframeTrace('click', {target: 'drop', item: $item.id}); const sentText = (feedbackBox &amp;&amp; feedbackBox.value) || (feedbackDraftsById || {})[$item.id] || ''; const r = window.__bramPrepareWorklistActionSubmission({kind: 'drop', items: worklist.value.items, selectedId: $item.id, rawFeedback: sentText, feedbackDraftsById: feedbackDraftsById || {}, expandedItemIds: expandedItemIds || [], voiceTarget: worklistVoiceTarget || 'message-agent', inflightTarget: 'drop'}); const next = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = next; if (feedbackBox) feedbackBox.setValue(''); window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); worklistActionResult = r; toTurn(r.turnText)" />
                    <Theme paddingHorizontal-Button-xs="$space-0_5">
                      <Button
                        label="ⓘ"
                        variant="ghost"
                        size="xs"
                        tooltip="What does Drop do?"
                        onClick="dropHelpDialog.open()" />
                    </Theme>
                  </HStack>
                  <Button
                    when="{submitting && actionProgressScope !== 'batch' && submittedItemId === $item.id}"
                    label="Cancel"
                    variant="ghost"
                    onClick="submitting = false; submittedItemId = null; submittedKind = null; window.__bramSetWorklistSubmittedKind(null); actionProgressScope = ''; actionProgressKind = ''; actionProgressTick = 0" />
                </HStack>
                <Text
                  when="{submitting &amp;&amp; actionProgressScope !== 'batch' &amp;&amp; submittedItemId === $item.id &amp;&amp; actionProgressKind}"
                  fontSize="$fontSize-sm"
                  fontStyle="italic"
                  color="$textColor-secondary"
                  value="{window.__bramInflightActionLabel(((inflightClaim.value &amp;&amp; (inflightClaim.value.ids || []).includes($item.id)) ? inflightClaim.value.kind : '') || actionProgressKind) + '.'.repeat(1 + (actionProgressTick % 3))}" />
                <Fragment when="{(expandedItemIds || []).includes($item.id)}">
                  <PastedImageStrip target="{'feedback:' + $item.id}" />
                </Fragment>
                <VStack
                  when="{(expandedItemIds || []).includes($item.id)}"
                  gap="$space-2"
                  paddingTop="$space-2">
                  <ExpandableItem
                    when="{$item.before || $item.after || $item.diff || window.__bramWorklistItemFiles($item).length > 0}"
                    summary="Details"
                    initiallyExpanded="false"
                    fullWidthSummary="true">
                    <VStack gap="$space-2">
                      <ExpandableItem
                        when="{window.__bramWorklistItemFiles($item).length > 0}"
                        summary="Files"
                        initiallyExpanded="false"
                        fullWidthSummary="true">
                        <VStack gap="$space-1">
                          <Items data="{window.__bramWorklistItemFiles($item)}">
                            <Text value="{$item}" variant="code" fontSize="$fontSize-sm" />
                          </Items>
                        </VStack>
                      </ExpandableItem>
                      <ExpandableItem
                        when="{$item.before}"
                        summary="Before"
                        initiallyExpanded="false"
                        fullWidthSummary="true">
                        <Markdown content="{$item.before}" />
                      </ExpandableItem>
                      <ExpandableItem
                        when="{$item.after}"
                        summary="After"
                        initiallyExpanded="false"
                        fullWidthSummary="true">
                        <Markdown content="{$item.after}" />
                      </ExpandableItem>
                      <ExpandableItem
                        when="{$item.diff}"
                        summary="Diff"
                        initiallyExpanded="false"
                        fullWidthSummary="true">
                        <VStack gap="$space-1">
                          <DiffView text="{($item.diff || '').slice(0, 20000)}" />
                          <Text
                            when="{($item.diff || '').length > 20000}"
                            fontSize="$fontSize-xs"
                            color="$textColor-secondary"
                            value="{'Diff preview truncated at 20 KB for responsiveness.'}" />
                        </VStack>
                      </ExpandableItem>
                    </VStack>
                  </ExpandableItem>
                </VStack>
              </VStack>
            </HStack>
          </VStack>
        </Items>
      </VStack>
      </VStack>
      </VStack>

    </VStack>
    </VStack>

    <ModalDialog
      id="statusProposedHelpDialog"
      title="TO APPLY">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          The agent is asking permission to make file edits. Nothing has happened
          on disk yet. In this phase you can:
        </Text>
        <Markdown content="- **Open** the item you want to act on by clicking its chevron (`▶` becomes `▼` when open). Multiple items can stay open at once.
- Click **Approve** to authorize the edits — the agent applies and the item transitions to TO COMMIT.
- Click **Drop** to discard the item — it's removed without any file changes.
- Ask the agent in chat to tweak an item's scope, before/after prose, or split it up — useful when the proposal is *almost* right." />
        <HStack>
          <Button label="Got it" onClick="statusProposedHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      id="feedbackProposedHelpDialog"
      title="Per-item feedback (TO APPLY)">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Your note travels with this specific item, whichever button you click:
        </Text>
        <Markdown content="- **Approve** — extra guidance for the agent while applying the proposal.
- **Iterate** — refinement direction; item stays TO APPLY (the agent revises the proposal text in place).
- **Drop** — reason for the drop." />
        <HStack>
          <Button label="Got it" onClick="feedbackProposedHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      id="feedbackAppliedHelpDialog"
      title="Per-item feedback (TO COMMIT)">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Your note travels with this specific item, whichever button you click:
        </Text>
        <Markdown content="- **Approve** — extra guidance for the agent when committing.
- **Iterate** — refinement direction; item stays TO COMMIT (the agent edits files in place and expands the item's after).
- **Drop** — reason for the drop. Files stay on disk; ask the agent to discard if you want them gone." />
        <HStack>
          <Button label="Got it" onClick="feedbackAppliedHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <Theme
      maxWidth-ModalDialog="50vw"
      backgroundColor-ModalDialog="$color-surface-50"
      backgroundColor-overlay-ModalDialog="rgba(15, 23, 42, 0.42)"
      borderRadius-ModalDialog="$borderRadius-lg"
      padding-ModalDialog="$space-6"
      fontSize-title-ModalDialog="$fontSize-xl"
      fontWeight-title-ModalDialog="$fontWeight-bold"
      textColor-title-ModalDialog="$color-primary-700"
      marginBottom-title-ModalDialog="$space-4">
    <ModalDialog
      when="{closeIssuesDialog !== null}"
      title="Close referenced issue(s)?"
      onClose="closeIssuesDialog = null; closeIssuesItemRef = null; closeIssuesState = null">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          This commit is flagged as resolving the GitHub issue(s) below.
          Confirm to let the close helper commit this worklist item, push the current branch, verify GitHub can see the commit, then close with a commit-link comment.
        </Text>
        <VStack
          gap="$space-2"
          padding="$space-3"
          border="{closeIssueExistingPendingCount(commits.value) > 0 ? '1px solid $color-warning-300' : '1px solid $color-surface-200'}"
          borderRadius="$borderRadius"
          backgroundColor="{closeIssueExistingPendingCount(commits.value) > 0 ? '$color-warning-50' : '$color-surface-100'}">
          <Text fontWeight="$fontWeight-bold">
            Push-before-close scope
          </Text>
          <Text fontSize="$fontSize-sm" color="$textColor-secondary">
            A branch push publishes the new worklist commit plus every unpublished commit already reachable from this branch tip.
          </Text>
          <Text
            when="{closeIssueExistingPendingCount(commits.value) > 0}"
            fontSize="$fontSize-sm"
            color="$color-warning-700"
            fontWeight="$fontWeight-bold">
            This close path will also push {closeIssueExistingPendingCount(commits.value)} existing pending commit(s).
          </Text>
          <VStack border="1px solid $color-surface-300" borderRadius="$borderRadius">
            <HStack gap="$space-2" padding="$space-2" backgroundColor="$color-surface-200">
              <Text width="70px" fontWeight="$fontWeight-bold" fontSize="$fontSize-xs">Commit</Text>
              <Text width="*" fontWeight="$fontWeight-bold" fontSize="$fontSize-xs">Subject</Text>
              <Text width="190px" fontWeight="$fontWeight-bold" fontSize="$fontSize-xs">Relation</Text>
            </HStack>
            <Items data="{closeIssuePushScopeRows(closeIssuesItemRef, commits.value)}">
              <HStack gap="$space-2" padding="$space-2" borderTop="1px solid $color-surface-200">
                <Text width="70px" variant="code" fontSize="$fontSize-xs" value="{$item.sha}" />
                <Text width="*" fontSize="$fontSize-sm" maxLines="2" value="{$item.subject}" />
                <Text width="190px" fontSize="$fontSize-xs" color="$textColor-secondary" value="{$item.relation}" />
              </HStack>
            </Items>
          </VStack>
        </VStack>
        <Items data="{closeIssuesItemRef ? closeIssuesItemRef.closesIssues : []}">
          <VStack
            gap="$space-2"
            padding="$space-3"
            border="1px solid $color-surface-200"
            borderRadius="$borderRadius"
            backgroundColor="$backgroundColor-primary"
            var.issue="{normalizeCloseIssue($item)}">
            <HStack gap="$space-2" verticalAlignment="start">
              <Text fontWeight="$fontWeight-bold" width="*" overflowMode="flow" breakMode="word">
                Closes #{issue.number}{issue.title ? ' — ' + issue.title : ''}
              </Text>
            </HStack>
            <TextArea
              placeholder="Optional close comment for #{issue.number}"
              autoComplete="off"
              autoCorrect="{false}"
              spellCheck="{false}"
              autoCapitalize="off"
              resize="vertical"
              minRows="1"
              maxRows="8"
              width="100%"
              onDidChange="(v) => closeIssuesState = setCloseIssueComment(closeIssuesState, issue.number, v)" />
          </VStack>
        </Items>
        <HStack gap="$space-2" paddingTop="$space-3" borderTop="1px solid $borderColor">
          <Button
            label="Confirm"
            tooltip="Commit, push this commit through the verified close helper, then close"
            onClick="const sentId = closeIssuesItemRef &amp;&amp; closeIssuesItemRef.id; const sentText = sentId ? ((feedbackDraftsById || {})[sentId] || '') : ''; const r = window.__bramPrepareCloseIssueWorklistActionSubmission({item: closeIssuesItemRef, closeIssuesState: closeIssuesState, closeIssues: true, feedbackDraftsById: feedbackDraftsById || {}, expandedItemIds: expandedItemIds || [], voiceTarget: worklistVoiceTarget || 'message-agent'}); const next = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = next; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); worklistActionResult = r; toTurn(r.turnText); closeIssuesDialog = null; closeIssuesItemRef = null; closeIssuesState = null" />
          <Button
            label="Approve without closing"
            variant="outlined"
            onClick="const sentId = closeIssuesItemRef &amp;&amp; closeIssuesItemRef.id; const sentText = sentId ? ((feedbackDraftsById || {})[sentId] || '') : ''; const r = window.__bramPrepareCloseIssueWorklistActionSubmission({item: closeIssuesItemRef, closeIssues: false, feedbackDraftsById: feedbackDraftsById || {}, expandedItemIds: expandedItemIds || [], voiceTarget: worklistVoiceTarget || 'message-agent'}); const next = Object.assign({}, r.feedbackDraftsById || {}); feedbackDraftsById = next; window.__bramPersistWorklistUiState({expandedItemIds: expandedItemIds || [], feedbackDraftsById: feedbackDraftsById}); worklistActionResult = r; toTurn(r.turnText); closeIssuesDialog = null; closeIssuesItemRef = null; closeIssuesState = null" />
          <Button
            label="Cancel"
            variant="ghost"
            onClick="closeIssuesDialog = null; closeIssuesItemRef = null; closeIssuesState = null" />
        </HStack>
      </VStack>
    </ModalDialog>
    </Theme>

    <ModalDialog
      id="statusInvalidHelpDialog"
      title="Invalid status">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Only two statuses make sense for an item shown here: **TO APPLY**
          (the agent is asking permission to edit) and **TO COMMIT** (edits
          are on disk, ready for your commit approval). Anything else is a
          bug — usually a stale record left behind by an agent or the
          backend after a commit.
        </Text>
        <Markdown content="What to do:

- Click **Drop** to remove the item. It's the only action that's safe regardless of status.
- If the item represented real work that landed in a commit, the commit itself is still in git history — only the worklist row is being cleaned up.
- If you don't recognize the item at all, treat it as agent or backend noise and Drop it." />
        <HStack>
          <Button label="Got it" onClick="statusInvalidHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      id="statusAppliedHelpDialog"
      title="TO COMMIT">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          The agent has made the file edits and the change is sitting in your
          working tree, not yet committed. This phase is intentionally
          fluid — you don't have to approve or drop right away. You can:
        </Text>
        <Markdown content="- **Verify** the change actually does what was promised — reload the target app, run the affected feature, read the diff.
- **Ask for follow-on tweaks** that get folded into the *same* item (the agent expands the item's `after` and applies more edits, the commit you eventually approve covers the whole thing). This is preferred over proposing a sibling item.
- Click **Approve** when you're satisfied — the agent creates the git commit with the item's prose as the message.
- Click **Drop** if it turned out wrong — the worklist entry is removed, but **the disk edits stay** (the agent doesn't revert files unilaterally). Ask the agent to *discard those changes if you want them gone* — it knows how to use git commands like `git checkout -- &lt;file&gt;` or `git restore &lt;file&gt;`." />
        <HStack>
          <Button label="Got it" onClick="statusAppliedHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      id="approveHelpDialog"
      title="Approve">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Approves the selected item for the agent to act on. What that means
          depends on the item's current status:
        </Text>
        <Markdown content="- **TO APPLY** → authorizes the agent to make the proposed file edits. Before applying you can `Iterate`. After applying, the item transitions to TO COMMIT (the change is on disk but not yet committed).
- **TO COMMIT** → authorizes the agent to create the git commit. Before committing you can `Iterate`. After committing, the item is pruned from the worklist.

If the item carries `closesIssues` (because the agent detected the commit is likely an issue-closer), Approve on TO COMMIT first opens the close-issue confirm dialog. Any text in the per-item feedback box travels with the approval and gives the agent extra guidance." />
        <HStack>
          <Button label="Got it" onClick="approveHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      id="iterateHelpDialog"
      title="Iterate">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Refines the item in place — the channel for "keep working on this
          without yet approving or dropping." Requires non-empty per-item
          feedback (the button is disabled until you type something into the
          feedback box).
        </Text>
        <Markdown content="- **TO APPLY** → the agent revises the item's proposal text (`before` / `after` / `files`) per your feedback. The item stays TO APPLY. No file edits on disk.
- **TO COMMIT** → the agent edits the on-disk files per your feedback and may expand the item's `after` to reflect the new scope. The item stays TO COMMIT.

Iterate is the right move when the agent's first cut is *almost* what you want." />
        <HStack>
          <Button label="Got it" onClick="iterateHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <Theme
      maxWidth-ModalDialog="50vw"
      backgroundColor-ModalDialog="$color-surface-50"
      backgroundColor-overlay-ModalDialog="rgba(15, 23, 42, 0.42)"
      borderRadius-ModalDialog="$borderRadius-lg"
      padding-ModalDialog="$space-6"
      fontSize-title-ModalDialog="$fontSize-xl"
      fontWeight-title-ModalDialog="$fontWeight-bold"
      textColor-title-ModalDialog="$color-primary-700"
      marginBottom-title-ModalDialog="$space-4">
    <ModalDialog
      when="{newItemHelp}"
      title="Add a worklist item"
      onClose="newItemHelp = false; newItemIssue = null; newItemVoiceRecording = false; setWorklistVoiceTarget('message-agent'); newItemBox.setValue('')">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          The worklist is how you and the agent coordinate multi-step work.
          You don't add items here directly — you ask the agent in chat to
          propose one, optionally citing an open GitHub issue to address.
        </Text>
        <Markdown content="- **Ask the agent in chat** to propose a worklist item — e.g. *“propose a worklist item to fix the search box width”*.
- The agent writes an item to `resources/worklist.json`; it appears here as **TO APPLY**.
- Select an item, then click:
  - **Approve** — the agent makes the proposed edits; the item transitions to **TO COMMIT**.
  - **Iterate** — the agent revises the proposal in place (requires per-item feedback).
  - **Drop** — discard the item without acting.

Before you `Approve` a `TO-APPLY` item you can `Iterate` to refine the proposal. Before you `Approve` a `TO-COMMIT` item you can `Iterate` to test and revise the implementation.
" />
        <VStack
          gap="$space-2"
          padding="$space-3"
          border="1px solid $color-surface-200"
          borderRadius="$borderRadius"
          backgroundColor="$backgroundColor-primary">
          <Text fontWeight="$fontWeight-bold" fontSize="$fontSize-sm" value="Ask the agent to propose an item" />
          <ChangeListener
            listenTo="{voiceArrival.value &amp;&amp; voiceArrival.value.at}"
            onDidChange="() => { const ev = voiceArrival.value || null; const t = (ev &amp;&amp; ev.transcript) || ''; const target = (ev &amp;&amp; ev.meta &amp;&amp; ev.meta.target) || ''; if (target === 'new-item') { if (t &amp;&amp; newItemBox) window.__bramAppendVoiceToBox(newItemBox, t); newItemVoiceRecording = false; worklistVoiceRecordingActive = false; } }" />
          <HStack
            when="{newItemHelp &amp;&amp; !openIssues.value}"
            gap="$space-2"
            verticalAlignment="center">
            <Spinner />
            <Text fontSize="$fontSize-sm" color="$color-text-secondary" value="Loading open issues…" />
          </HStack>
          <Select
            when="{!!openIssues.value}"
            placeholder="Optional: cite an open issue"
            data="{((openIssues.value) || []).filter(i => i.state === 'OPEN').map(i => ({value: i.number, label: '#' + i.number + ' ' + i.title}))}"
            initialValue="{newItemIssue}"
            onDidChange="(v) => newItemIssue = v" />
          <HStack gap="$space-2" verticalAlignment="center">
            <TextArea
              id="newItemBox"
              placeholder="Describe what the item should change"
              autoFocus="true"
              autoComplete="off"
              autoCorrect="{false}"
              spellCheck="{false}"
              autoCapitalize="off"
              resize="vertical"
              minRows="4"
              maxRows="16"
              width="*"
              onInit="setWorklistVoiceTarget('new-item')"
              onGotFocus="setWorklistVoiceTarget('new-item')" />
            <Button
              label="{newItemVoiceRecording ? (worklistVoiceRecordingActive ? '⏹' : '⏳') : '🎤'}"
              variant="{newItemVoiceRecording ? 'solid' : 'outlined'}"
              enabled="{!isWorklistVoiceProcessingTarget('new-item') &amp;&amp; (!newItemVoiceRecording || worklistVoiceRecordingActive)}"
              onClick="setWorklistVoiceTarget('new-item'); newItemVoiceRecording = toggleVoiceForCurrentTarget(newItemVoiceRecording)" />
            <Theme size-Spinner="14px">
              <Spinner when="{isWorklistVoiceProcessingTarget('new-item')}" />
            </Theme>
          </HStack>
          <HStack gap="$space-2">
            <Button
              label="Send"
              enabled="{!newItemSubmitting &amp;&amp; (!!newItemIssue || (newItemBox.value &amp;&amp; newItemBox.value.trim().length > 0))}"
              onClick="(() => {
                const issuesArr = (openIssues.value) || [];
                const issueObj = newItemIssue ? issuesArr.find(i => String(i.number) === String(newItemIssue)) : null;
                const text = (newItemBox.value || '').trim();
                let msg;
                if (issueObj &amp;&amp; text) { msg = 'Propose a worklist item to address #' + issueObj.number + ' (' + issueObj.title + '): ' + text; }
                else if (issueObj) { msg = 'Propose a worklist item to address #' + issueObj.number + ' (' + issueObj.title + ').'; }
                else { msg = 'Propose a worklist item: ' + text; }
                newItemStartSig = lastWorklistSig;
                newItemTurnEnded = false;
                newItemSubmitting = true;
                submittedWorklistMessage = msg;
                submittedKind = window.__bramSetWorklistSubmittedKind('message');
                messageSentAtText = new Date().toLocaleTimeString();
                awaitingResponse = true;
                awaitingResponseSetAt = window.__bramMarkAwaitingStarted();
                toTurn(msg);
                newItemHelp = false; newItemIssue = null; newItemVoiceRecording = false; setWorklistVoiceTarget('message-agent'); newItemBox.setValue('');
              })()" />
            <Button
              label="Cancel"
              variant="ghost"
              onClick="newItemHelp = false; newItemIssue = null; newItemVoiceRecording = false; setWorklistVoiceTarget('message-agent'); newItemBox.setValue('')" />
          </HStack>
        </VStack>
      </VStack>
    </ModalDialog>
    </Theme>

    <ModalDialog
      id="dropHelpDialog"
      title="Drop">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          Removes the item from the worklist. The agent will not act on it.
        </Text>
        <Markdown content="- **TO APPLY** → the item is removed; nothing on disk changes.
- **TO COMMIT** → the item is removed, but the file edits the agent already made on your behalf **stay on disk**. If you want them gone, ask the agent to discard them — it knows how to use `git checkout -- &lt;file&gt;` or `git restore &lt;file&gt;`.

Drop is the clean rejection path; Iterate is what you want if the item just needs to change shape." />
        <HStack>
          <Button label="Got it" onClick="dropHelpDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

    <PushSource
      id="worklistChangedEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('worklist-changed')}" />
    <ChangeListener
      listenTo="{worklistChangedEvt.value &amp;&amp; worklistChangedEvt.value.tick}"
      onDidChange="() => {
        const payload = (worklistChangedEvt.value &amp;&amp; worklistChangedEvt.value.payload) || {};
        window.__bramIframeTrace('listener-fired', {paths: payload.paths || [], correlation_id: payload.id || ''});
        window.__bramIframeTrace('refetch-called', {context: 'worklist-changed'});
        worklist.refetch();
      }" />
    <PushSource
      id="agentTurnEndEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('agent-turn-end')}" />
    <ChangeListener
      listenTo="{agentTurnEndEvt.value &amp;&amp; agentTurnEndEvt.value.tick}"
      onDidChange="() => {
        if (newItemSubmitting) {
          newItemTurnEnded = true;
          worklist.refetch();
        }
        if (awaitingResponse) {
          agentTurnEndedSinceSubmit = true;
          if (window.__bramMarkTurnEnded('agent-turn-end', {awaitingResponse: awaitingResponse, submitting: submitting, awaitingResponseSetAt: awaitingResponseSetAt, submittedKind: submittedKind})) {
            awaitingResponse = false;
            submittedKind = null;
            window.__bramClearWorklistAwaiting(false);
          }
        }
      }" />
    <!-- The listener above used to drain ALL staged pasted images on every
         agent turn end, with no target. That silently ate images the user
         staged while the agent was still responding: the 2026-07-03
         skip-worklist image drop. Staged images now persist until a submit
         consumes them or the user removes them from the strip. -->
    <PushSource
      id="agentTurnKilledEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('agent-turn-killed')}" />
    <ChangeListener
      listenTo="{agentTurnKilledEvt.value &amp;&amp; agentTurnKilledEvt.value.tick}"
      onDidChange="() => {
        if (window.__bramMarkTurnEnded('agent-turn-killed', {awaitingResponse: awaitingResponse, submitting: submitting, awaitingResponseSetAt: awaitingResponseSetAt, submittedKind: submittedKind})) {
          awaitingResponse = false;
          submittedKind = null;
          window.__bramClearWorklistAwaiting(false);
        }
      }" />
    <PushSource
      id="inflightClaimChangedEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('inflight-claim-changed')}" />
    <ChangeListener
      listenTo="{inflightClaimChangedEvt.value &amp;&amp; inflightClaimChangedEvt.value.tick}"
      onDidChange="() => {
        window.__bramIframeTrace('listener-fired', {context: 'inflight-claim-changed'});
        inflightTick = inflightTick + 1;
      }" />
    <PushSource
      id="workspaceAgentStatusEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('agent-status-changed')}" />
    <!-- Key on payload.state (transitions), not .tick (every push): the handler
         only acts on a working->finished transition, so waking it on every
         ~1/sec elapsed tick was pure churn. See
         decouple-elapsed-from-agent-status-broadcast. -->
    <ChangeListener
      listenTo="{workspaceAgentStatusEvt.value &amp;&amp; workspaceAgentStatusEvt.value.payload &amp;&amp; workspaceAgentStatusEvt.value.payload.state}"
      onDidChange="() => {
        const p = (workspaceAgentStatusEvt.value &amp;&amp; workspaceAgentStatusEvt.value.payload) || null;
        if (awaitingResponse &amp;&amp; p &amp;&amp; p.state !== 'working') {
          if (p.state === 'finished' &amp;&amp; window.__bramMarkTurnEnded('agent-status-finished', {awaitingResponse: awaitingResponse, submitting: submitting, awaitingResponseSetAt: awaitingResponseSetAt, submittedKind: submittedKind})) {
            awaitingResponse = false;
            submittedKind = null;
            window.__bramClearWorklistAwaiting(false);
          }
        }
      }" />

    <!-- Agent dock: pending permission menu + the agent's last response, so
         you can read output and answer a menu without leaving the Worklist
         page for the Transcript tab. Menu = the shared bramSubscribeAgentMenu
         push (AgentMenuView is self-gating on $props.menu and sends the
         option keys). Last response = conversationStateDS.value
         .lastAssistantText.text, bounded with an internal scroller so a long
         response doesn't lengthen the page. -->
    <VStack
      when="{agentMenuEvt.value || (conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; conversationStateDS.value.lastExchange.userText) || (conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; conversationStateDS.value.lastExchange.userImages &amp;&amp; conversationStateDS.value.lastExchange.userImages.length > 0) || (conversationStateDS.value &amp;&amp; conversationStateDS.value.lastAssistantText &amp;&amp; conversationStateDS.value.lastAssistantText.text)}"
      gap="$space-2"
      width="100%"
      paddingTop="$space-4">
      <AgentMenuView menu="{agentMenuEvt.value}" surface="worklist" />
      <VStack
        when="{conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; (conversationStateDS.value.lastExchange.userText || (conversationStateDS.value.lastExchange.userImages &amp;&amp; conversationStateDS.value.lastExchange.userImages.length > 0))}"
        gap="$space-1"
        width="100%"
        var.youText="{conversationStateDS.value.lastExchange.userText || ''}"
        var.youImages="{conversationStateDS.value.lastExchange.userImages || []}">
        <Text
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          value="You: last message" />
        <VStack maxHeight="12em" overflowY="auto" width="100%">
          <Markdown when="{youText}" content="{youText}" />
          <VStack when="{youImages.length > 0}" gap="$space-2" paddingVertical="$space-1">
            <Items data="{youImages}">
              <Link onClick="fullscreenImage = $item" noIndicator="true">
                <Image src="{window.imageSrcForPath($item)}" maxHeight="220px" fit="contain" />
              </Link>
            </Items>
          </VStack>
        </VStack>
      </VStack>
      <!-- Dim the agent response on Workspace launch, or while a newer user
           message has arrived but the agent has not answered it yet. The launch
           dim clears when a newer assistant response arrives, the newer
           exchange has an assistant answer, or a remounted page recognizes
           the answered exchange as a Worklist submission from this app
           session. -->
      <VStack
        when="{conversationStateDS.value &amp;&amp; conversationStateDS.value.lastAssistantText &amp;&amp; conversationStateDS.value.lastAssistantText.text}"
        gap="$space-1"
        width="100%"
        opacity="{(agentDockLaunchResponseDim || (conversationStateDS.value &amp;&amp; conversationStateDS.value.lastExchange &amp;&amp; conversationStateDS.value.lastExchange.userText &amp;&amp; !conversationStateDS.value.lastExchange.assistantText)) ? 0.45 : 1}"
        var.lastResp="{conversationStateDS.value.lastAssistantText.text}">
        <Text
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          value="Agent: last response" />
        <VStack maxHeight="20em" overflowY="auto" width="100%">
          <Markdown content="{window.__bramStripImagePaths(lastResp)}" />
        </VStack>
      </VStack>
    </VStack>

  </VStack>
</Component>

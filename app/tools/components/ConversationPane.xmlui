<Component
  name="ConversationPane"
  var.fullscreenImage="{null}"
  var.heldTexts="{[]}"
  var.heldImages="{[]}"
  var.hasFreshTexts="{!!($props.exchange &amp;&amp; $props.exchange.assistantTexts &amp;&amp; $props.exchange.assistantTexts.length > 0)}"
  var.displayTexts="{hasFreshTexts ? $props.exchange.assistantTexts : heldTexts}"
  var.displayImages="{hasFreshTexts ? ($props.exchange.assistantImages || []) : heldImages}">
  <!-- Sources the exchange from Workspace's conversationStateDS
       (/__conversation-state, static URL refreshed in place via .refetch()).
       The source no longer blanks per-refetch (see
       stabilize-conversation-state-refetch-no-blank: the URL cache-buster that
       made .value oscillate blank<->content was removed), so the pane renders
       directly from $props.exchange -- no heldExchange bridge needed.

       Layout: a plain flex column. The "You" block and the "Agent: Tool uses"
       widget take natural height; the "Agent: Last response" region is a
       height="*" (star/flex-fill) child that grows to fill the remaining space
       and scrolls within its own bottom-anchored List. The confirmed
       fill-and-scroll pattern is height="*" on the List (NOT height="100%",
       which is percentage-of-parent and collapses when an ancestor is
       unbounded) -- see the scrollToBottom example at
       https://www.xmlui.org/docs/reference/components/List#scrolltobottom and
       the in-codebase nested star-fill at Workspace.xmlui (VStack height="*"
       containing HSplitter height="*"). The list was inlined here rather than
       left inside an AgentLastResponse user-defined component because neither
       confirmed example crosses a UDC boundary; star sizing through a UDC
       wrapper was the unverified step that left scrollToBottom a no-op.

       assistantTexts is the ordered list of this turn's assistant text blocks;
       each streams in as the backend re-reads the session JSONL mid-turn, so
       the list grows one row per emitted message and bottom-anchors to keep the
       newest visible -- the symmetric twin of AgentToolUses' tool List.

       Dim semantics: dimmed === looking at the PREVIOUS response while awaiting
       the next one (hasFreshTexts === false). heldTexts/heldImages keep the
       prior response visible (dimmed) until the first fresh message of the new
       turn arrives, at which point the held view is replaced and it brightens.

       ChangeListener does not fire on initial mount
       (https://docs.xmlui.org/howto/debounce-with-changelistener). -->
  <ChangeListener
    listenTo="{window.assistantOutputSignature($props.exchange) + '|' + (($props.exchange &amp;&amp; $props.exchange.tools &amp;&amp; $props.exchange.tools.length) || 0)}"
    onDidChange="() => {
      const text = ($props.exchange &amp;&amp; $props.exchange.assistantText) || '';
      window.__bramIframeTrace('conversation-value-changed', {assistantSig: window.assistantOutputSignature($props.exchange), assistantTextLen: text.length, toolsLen: ($props.exchange &amp;&amp; $props.exchange.tools &amp;&amp; $props.exchange.tools.length) || 0, hasAssistant: !!text});
    }" />
  <ChangeListener
    listenToSources="{{exchange: $props.exchange}}"
    onDidChange="() => { const txts = ($props.exchange &amp;&amp; $props.exchange.assistantTexts) || []; if (txts.length) { heldTexts = txts; heldImages = ($props.exchange &amp;&amp; $props.exchange.assistantImages) || []; } }" />
  <ChangeListener
    listenTo="{hasFreshTexts}"
    onDidChange="(c) => window.__bramIframeTrace('conversation-fade', {stage: c.newValue ? 'fade-in' : 'dim', trigger: 'response-text', hasText: !!c.newValue})" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{window.imageSrcForPath(fullscreenImage)}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack gap="$space-3" padding="$space-3">
    <VStack
      gap="$space-1"
      when="{$props.exchange &amp;&amp; ($props.exchange.userText || (($props.exchange.userImages || []).length > 0))}"
      var.userImagePreviews="{(($props.exchange &amp;&amp; $props.exchange.userImages) || []).length > 0 ? $props.exchange.userImages : window.__bramExtractImagePaths(($props.exchange &amp;&amp; $props.exchange.userText) || '').concat(window.__bramExtractImagePaths(($props.exchange &amp;&amp; $props.exchange.iterateFeedback) || ''))}">
        <Text
          fontWeight="$fontWeight-bold"
          color="$color-info-700"
          value="You" />
      <Markdown content="{window.__bramStripImagePaths(window.__bramConversationPaneUserText($props.exchange.userText)) + (($props.exchange &amp;&amp; $props.exchange.iterateFeedback) ? '\n\n' + window.__bramStripImagePaths($props.exchange.iterateFeedback) : '')}" />
      <VStack
        gap="$space-2"
        when="{userImagePreviews &amp;&amp; userImagePreviews.length > 0}">
        <Items data="{userImagePreviews}">
          <Link onClick="fullscreenImage = $item" noIndicator="true">
            <Image
              src="{window.imageSrcForPath($item)}"
              maxHeight="200px"
              fit="contain" />
          </Link>
        </Items>
      </VStack>
    </VStack>
    <AgentToolUses
      exchange="{$props.exchange}"
      active="{$props.exchange &amp;&amp; conversationActive($props.exchange)}" />
    <VStack
      gap="$space-1"
      opacity="{hasFreshTexts ? 1 : 0.55}"
      transition="opacity 560ms ease-out"
      when="{$props.exchange &amp;&amp; conversationActive($props.exchange)}">
      <Text
        fontWeight="$fontWeight-bold"
        color="$color-success-700"
        value="Agent: Last response" />
      <List
        data="{displayTexts}"
        maxHeight="60vh"
        scrollAnchor="bottom">
        <property name="emptyListTemplate"><Fragment/></property>
        <Markdown content="{window.__bramStripImagePaths($item || '')}" />
      </List>
      <VStack
        gap="$space-2"
        when="{displayImages &amp;&amp; displayImages.length > 0}">
        <Items data="{displayImages}">
          <Link onClick="fullscreenImage = $item" noIndicator="true">
            <Image
              src="{window.imageSrcForPath($item)}"
              maxHeight="200px"
              fit="contain" />
          </Link>
        </Items>
      </VStack>
    </VStack>
    <Text
      when="{!$props.exchange || (!$props.exchange.userText &amp;&amp; !$props.exchange.assistantText &amp;&amp; (!$props.exchange.tools || $props.exchange.tools.length === 0))}"
      fontSize="$fontSize-sm">
      No recent exchange to show.
    </Text>
  </VStack>
</Component>

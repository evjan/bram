<Component name="AgentLastResponse" var.fullscreenImage="{null}" var.replyArriving="{false}" var.lastResponseCueKey="{null}">
  <DataSource id="agentLastResponseExchange" url="/__last-exchange" />
  <VStack
    width="0"
    height="0"
    onInit="subscribeTalkSessionChange('__bramAgentLastResponseTalkSessionUnsub', () => debounce(400, () => agentLastResponseExchange.refetch()))" />
  <ChangeListener
    listenTo="{((agentLastResponseExchange.value &amp;&amp; agentLastResponseExchange.value.assistantText) || '') + '|' + (((agentLastResponseExchange.value &amp;&amp; agentLastResponseExchange.value.assistantImages) || []).join('|'))}"
    onDidChange="(change) => {
      const nextKey = change.newValue || '';
      if (lastResponseCueKey === null) {
        lastResponseCueKey = nextKey;
        return;
      }
      if (nextKey && nextKey !== lastResponseCueKey) {
        lastResponseCueKey = nextKey;
        replyArriving = true;
      } else {
        lastResponseCueKey = nextKey;
      }
    }" />
  <Timer
    enabled="{replyArriving}"
    initialDelay="360"
    interval="360"
    once="true"
    onTick="replyArriving = false" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{(fullscreenImage || '').startsWith('data:') || (fullscreenImage || '').startsWith('http') ? fullscreenImage : '/__file?path=' + encodeURIComponent((fullscreenImage || '').startsWith('file://') ? (fullscreenImage || '').replace(/^file:\/\/(localhost)?/, '') : (fullscreenImage || ''))}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack
    gap="$space-1"
    opacity="{replyArriving ? 0.55 : 1}"
    transition="opacity 560ms ease-out"
    when="{agentLastResponseExchange.value &amp;&amp; (agentLastResponseExchange.value.assistantText || (agentLastResponseExchange.value.assistantImages &amp;&amp; agentLastResponseExchange.value.assistantImages.length > 0))}">
    <Text
      fontWeight="$fontWeight-bold"
      color="$color-success-700"
      value="Agent: Last response" />
    <Markdown content="{stripImagePaths(agentLastResponseExchange.value &amp;&amp; agentLastResponseExchange.value.assistantText)}" />
    <VStack
      gap="$space-2"
      when="{agentLastResponseExchange.value &amp;&amp; agentLastResponseExchange.value.assistantImages &amp;&amp; agentLastResponseExchange.value.assistantImages.length > 0}">
      <Items data="{agentLastResponseExchange.value.assistantImages}">
        <Link onClick="fullscreenImage = $item" noIndicator="true">
          <Image
            src="{$item.startsWith('data:') || $item.startsWith('http') ? $item : '/__file?path=' + encodeURIComponent($item.startsWith('file://') ? $item.replace(/^file:\/\/(localhost)?/, '') : $item)}"
            maxHeight="200px"
            fit="contain" />
        </Link>
      </Items>
    </VStack>
  </VStack>
</Component>

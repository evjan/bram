<Component
  name="Settings"
  var.agentDraft="{''}"
  var.argsDraft="{''}"
  var.firstDraft="{''}"
  var.continueDraft="{false}"
  var.infoTitle="{''}"
  var.infoBody="{''}">

  <DataSource
    id="settingsConfig"
    url="/__settings"
    onLoaded="(v) => { agentDraft = settingsAgent(v); argsDraft = settingsArgs(v); firstDraft = settingsFirstCommand(v); continueDraft = settingsContinueLast(v); }" />

  <APICall
    id="saveSettings"
    method="post"
    url="/__settings"
    body="{$param}"
    onSuccess="settingsConfig.refetch()" />

  <VStack
    padding="$space-6"
    gap="$space-5">
    <PushSource
      id="settingsChangedEvt"
      initial="{null}"
      subscribe="{window.bramSubscribeTauriEvent('settings-changed')}" />
    <ChangeListener
      listenTo="{settingsChangedEvt.value &amp;&amp; settingsChangedEvt.value.tick}"
      onDidChange="() => { window.__bramIframeTrace('refetch-called', {context: 'settings-changed'}); settingsConfig.refetch(); }" />

    <Heading level="h2">Settings</Heading>
    <Text
      fontSize="$fontSize-sm"
      color="$textColor-secondary"
      value="Mirrors .bram.json in the project root. Changes save immediately and persist there." />

    <VStack when="{settingsConfig.value}" gap="$space-5">

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Shell"
            onClick="infoTitle = 'Shell'; infoBody = window.settingsInfoBodies.shell; settingInfoDialog.open()" />
          <Heading level="h3">Shell</Heading>
        </HStack>
        <Select
          id="agentBox"
          width="25%"
          initialValue="{settingsAgent(settingsConfig.value)}"
          onDidChange="(v) => agentDraft = v">
          <Option value="claude" label="Claude" />
          <Option value="codex" label="Codex" />
        </Select>
        <TextBox
          id="argsBox"
          width="25%"
          placeholder="optional launch arguments"
          initialValue="{settingsArgs(settingsConfig.value)}"
          autoComplete="off"
          autoCorrect="{false}"
          spellCheck="{false}"
          autoCapitalize="off"
          onDidChange="(v) => argsDraft = v" />
        <TextBox
          id="firstCommandBox"
          width="25%"
          placeholder="optional first command"
          initialValue="{settingsFirstCommand(settingsConfig.value)}"
          autoComplete="off"
          autoCorrect="{false}"
          spellCheck="{false}"
          autoCapitalize="off"
          onDidChange="(v) => firstDraft = v" />
        <Switch
          label="Continue most recent session on startup"
          initialValue="{settingsContinueLast(settingsConfig.value)}"
          onDidChange="(v) => continueDraft = v" />
        <HStack>
          <Button
            label="Save"
            enabled="{(agentDraft !== settingsAgent(settingsConfig.value) || argsDraft !== settingsArgs(settingsConfig.value) || firstDraft !== settingsFirstCommand(settingsConfig.value) || continueDraft !== settingsContinueLast(settingsConfig.value)) &amp;&amp; agentDraft.trim().length > 0}"
            onClick="saveSettings.execute({ shell: { agent: agentDraft, args: argsDraft, firstCommand: firstDraft, continueLast: continueDraft } })" />
        </HStack>
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Worklist"
            onClick="infoTitle = 'Worklist'; infoBody = window.settingsInfoBodies.batchCommitActions; settingInfoDialog.open()" />
          <Heading level="h3">Worklist</Heading>
        </HStack>
        <Switch
          label="Batch commit actions"
          initialValue="{settingsBatch(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ worklist: { batchCommitActions: v } })" />
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About UI"
            onClick="infoTitle = 'UI'; infoBody = window.settingsInfoBodies.ui; settingInfoDialog.open()" />
          <Heading level="h3">UI</Heading>
        </HStack>
        <Switch
          label="Show target app"
          initialValue="{settingsShowTargetApp(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ ui: { showTargetApp: v } })" />
        <Switch
          label="Agent-pane hot-reload"
          initialValue="{settingsToolsPaneHotReload(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ ui: { toolsPaneHotReload: v } })" />
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Traces"
            onClick="infoTitle = 'Traces'; infoBody = window.settingsInfoBodies.traces; settingInfoDialog.open()" />
          <Heading level="h3">Traces</Heading>
        </HStack>
        <Switch
          label="Tracing enabled"
          initialValue="{settingsTracingEnabled(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ traces: { enabled: v } })" />
        <Switch
          label="Inspector trace tap"
          initialValue="{settingsInspectorTap(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ traces: { inspectorTap: v } })" />
      </VStack>

    </VStack>

    <Text
      when="{settingsConfig.error}"
      color="$color-danger-700"
      fontSize="$fontSize-sm"
      value="Settings failed to load." />

    <ModalDialog id="settingInfoDialog" title="{infoTitle}">
      <VStack gap="$space-3" padding="$space-2">
        <Markdown content="{infoBody}" />
        <HStack>
          <Button label="Got it" onClick="settingInfoDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

  </VStack>
</Component>

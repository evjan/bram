<Component name="ConversationPane" var.fullscreenImage="{null}" var.lastRefetchReason="{''}" var.lastRefetchAt="{0}">
  <!-- One stable-URL DataSource, refreshed in place by the talk-session event
       only (the ChangeListener below calls lastExchange.refetch(), debounced).
       No steady poll: a 1s poll re-rendered the growing full-turn Markdown
       every tick during streaming and starved the shared renderer thread,
       which showed up as multi-second getUserMedia/mic-start latency. The
       event fires on real JSONL changes, so the pane still updates live and
       accumulates. Never put a changing tick in the URL -- that restarts the
       query and blanks .value (the flash). See docs/conversation-pane.md. -->
  <DataSource id="lastExchange" url="/__last-exchange" />
  <External
    id="convoTalkEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTalkSessionChange()}" />
  <ChangeListener
    listenTo="{convoTalkEvt.value &amp;&amp; convoTalkEvt.value.at}"
    onDidChange="() => debounce(250, () => {
      const text = (lastExchange.value &amp;&amp; lastExchange.value.assistantText) || '';
      lastRefetchReason = 'talk-session';
      lastRefetchAt = Date.now();
      window.__bramIframeTrace('conversation-refetch', {reason: lastRefetchReason, assistantSig: window.assistantOutputSignature(lastExchange.value), assistantTextLen: text.length, toolsLen: (lastExchange.value &amp;&amp; lastExchange.value.tools &amp;&amp; lastExchange.value.tools.length) || 0});
      lastExchange.refetch();
    })" />
  <External
    id="convoAgentStatusEvt"
    initial="{null}"
    subscribe="{window.bramSubscribeTauriEvent('agent-status-changed')}" />
  <ChangeListener
    listenTo="{convoAgentStatusEvt.value &amp;&amp; convoAgentStatusEvt.value.tick}"
    onDidChange="() => {
      const payload = (convoAgentStatusEvt.value &amp;&amp; convoAgentStatusEvt.value.payload) || {};
      window.__bramIframeTrace('conversation-finished-signal', {event: 'agent-status-changed', state: payload.state || '', phase: payload.phase || '', provider: payload.provider || '', source: payload.source || ''});
      if (payload.state === 'finished') {
        debounce(650, () => {
          const text = (lastExchange.value &amp;&amp; lastExchange.value.assistantText) || '';
          lastRefetchReason = 'agent-status-finished';
          lastRefetchAt = Date.now();
          window.__bramIframeTrace('conversation-refetch', {reason: lastRefetchReason, provider: payload.provider || '', source: payload.source || '', state: payload.state || '', phase: payload.phase || '', assistantSig: window.assistantOutputSignature(lastExchange.value), assistantTextLen: text.length, toolsLen: (lastExchange.value &amp;&amp; lastExchange.value.tools &amp;&amp; lastExchange.value.tools.length) || 0});
          lastExchange.refetch();
        });
      }
    }" />
  <ChangeListener
    listenTo="{window.assistantOutputSignature(lastExchange.value) + '|' + ((lastExchange.value &amp;&amp; lastExchange.value.tools &amp;&amp; lastExchange.value.tools.length) || 0)}"
    onDidChange="() => {
      const text = (lastExchange.value &amp;&amp; lastExchange.value.assistantText) || '';
      window.__bramIframeTrace('conversation-value-changed', {reason: lastRefetchReason, sinceRefetchMs: lastRefetchAt ? (Date.now() - lastRefetchAt) : -1, assistantSig: window.assistantOutputSignature(lastExchange.value), assistantTextLen: text.length, toolsLen: (lastExchange.value &amp;&amp; lastExchange.value.tools &amp;&amp; lastExchange.value.tools.length) || 0, hasAssistant: !!text, isRefetch: !!(lastExchange.isRefetching)});
    }" />
  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{window.imageSrcForPath(fullscreenImage)}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>
  <VStack gap="$space-3" padding="$space-3">
    <VStack
      gap="$space-1"
      when="{lastExchange.value &amp;&amp; (lastExchange.value.userText || ((lastExchange.value.userImages || []).length > 0))}"
      var.userImagePreviews="{((lastExchange.value &amp;&amp; lastExchange.value.userImages) || []).length > 0 ? lastExchange.value.userImages : window.__bramExtractImagePaths((lastExchange.value &amp;&amp; lastExchange.value.userText) || '').concat(window.__bramExtractImagePaths((lastExchange.value &amp;&amp; lastExchange.value.iterateFeedback) || ''))}">
        <Text
          fontWeight="$fontWeight-bold"
          color="$color-info-700"
          value="You" />
      <Markdown content="{window.__bramStripImagePaths(window.__bramConversationPaneUserText(lastExchange.value.userText)) + ((lastExchange.value &amp;&amp; lastExchange.value.iterateFeedback) ? '\n\n' + window.__bramStripImagePaths(lastExchange.value.iterateFeedback) : '')}" />
      <VStack
        gap="$space-2"
        when="{userImagePreviews &amp;&amp; userImagePreviews.length > 0}">
        <Items data="{userImagePreviews}">
          <Link onClick="fullscreenImage = $item" noIndicator="true">
            <Image
              src="{window.imageSrcForPath($item)}"
              maxHeight="200px"
              fit="contain" />
          </Link>
        </Items>
      </VStack>
    </VStack>
    <AgentToolUses
      exchange="{lastExchange.value}"
      active="{lastExchange.loaded &amp;&amp; conversationActive(lastExchange.value)}" />
    <AgentLastResponse
      exchange="{lastExchange.value}"
      active="{lastExchange.loaded &amp;&amp; conversationActive(lastExchange.value)}" />
    <Text
      when="{!lastExchange.value || (!lastExchange.value.userText &amp;&amp; !lastExchange.value.assistantText &amp;&amp; (!lastExchange.value.tools || lastExchange.value.tools.length === 0))}"
      fontSize="$fontSize-sm">
      No recent exchange to show.
    </Text>
  </VStack>
</Component>

<Component name="AgentMenuView">
  <!-- Presentational pending-menu box. Takes the parsed menu as $props.menu
       so it can be rendered both as a standalone banner and inline in the
       Transcript event flow (where $item shadowing would otherwise collide
       with the per-option Items below).

       Preview is open by default and single-scroller: the inline body hugs
       its content (compact DiffView = plain rows, no virtualized 60vh List,
       no inner scrollbar) and, past an inline line cap, spills the full
       diff/content to a component-owned modal so nothing double-scrolls. The
       modal lives here (not on the host page) so it works identically on the
       Transcript and the Worklist-dock surfaces. -->
  <VStack
    when="{$props.menu}"
    gap="$space-2"
    var.menuIdentity="{window.__bramMenuIdentity($props.menu)}"
    var.menuPreviewOpen="{true}"
    var.previewModalOpen="{false}"
    width="100%"
    onInit="window.__bramTraceAgentMenuRender($props.menu, $props.surface || 'component')"
    padding="$space-3"
    borderRadius="$borderRadius"
    border="1px solid $color-warn-200"
    backgroundColor="$color-warn-50">
    <Text fontSize="$fontSize-xs" color="$color-warn-800">
      Agent wants to use <Text fontFamily="$fontFamily-monospace">{$props.menu.tool}</Text>
    </Text>
    <Button
      when="{$props.menu.toolCallSignature || $props.menu.toolCallContent || $props.menu.text}"
      label="{menuPreviewOpen ? 'Hide preview' : 'Show preview'}"
      variant="ghost"
      size="xs"
      onClick="menuPreviewOpen = !menuPreviewOpen" />

    <!-- signature only (no diff): short, render inline -->
    <VStack
      when="{menuPreviewOpen &amp;&amp; $props.menu.toolCallSignature &amp;&amp; !$props.menu.toolCallDiff}"
      padding="$space-2"
      borderRadius="$borderRadius"
      backgroundColor="$color-surface-100">
      <Text
        value="{$props.menu.toolCallSignature}"
        fontFamily="$fontFamily-monospace"
        fontSize="$fontSize-sm"
        preserveLinebreaks="true" />
    </VStack>

    <!-- diff: compact content-hugging rows capped to the inline window;
         longer diffs spill to the modal -->
    <VStack
      when="{menuPreviewOpen &amp;&amp; $props.menu.toolCallDiff}"
      gap="$space-1"
      padding="$space-2"
      borderRadius="$borderRadius"
      backgroundColor="$color-surface-100"
      var.diffLines="{($props.menu.toolCallDiff || '').split('\n')}">
      <DiffView compact="true" text="{diffLines.slice(0, 24).join('\n')}" />
      <Button
        when="{diffLines.length > 24}"
        label="View full diff ({diffLines.length} lines)"
        variant="ghost"
        size="xs"
        onClick="previewModalOpen = true" />
    </VStack>

    <!-- content (Write body etc.): capped Markdown; overflow to modal -->
    <VStack
      when="{menuPreviewOpen &amp;&amp; $props.menu.toolCallContent}"
      gap="$space-1"
      padding="$space-2"
      borderRadius="$borderRadius"
      backgroundColor="$color-surface-100"
      var.contentLines="{($props.menu.toolCallContent || '').split('\n')}">
      <Markdown content="{contentLines.slice(0, 24).join('\n')}" />
      <Button
        when="{contentLines.length > 24}"
        label="View full ({contentLines.length} lines)"
        variant="ghost"
        size="xs"
        onClick="previewModalOpen = true" />
    </VStack>

    <!-- prose / command text (no signature) -->
    <VStack
      when="{menuPreviewOpen &amp;&amp; !$props.menu.toolCallSignature &amp;&amp; $props.menu.text}"
      padding="$space-2"
      borderRadius="$borderRadius"
      backgroundColor="$color-surface-100">
      <!-- AskUserQuestion's text is a prose question -> body font. Other
           menus' text can be a command-like preview -> keep monospace. -->
      <Text
        when="{$props.menu.tool === 'AskUserQuestion'}"
        value="{$props.menu.text}"
        fontSize="$fontSize-sm"
        preserveLinebreaks="true" />
      <Text
        when="{$props.menu.tool !== 'AskUserQuestion'}"
        value="{$props.menu.text}"
        fontFamily="$fontFamily-monospace"
        fontSize="$fontSize-xs"
        preserveLinebreaks="true" />
    </VStack>

    <VStack
      when="{$props.menu.options &amp;&amp; $props.menu.options.length > 0}"
      gap="$space-1"
      width="100%">
      <Theme paddingHorizontal-Button-sm="$space-3">
        <Items data="{$props.menu.options}">
          <HStack gap="$space-2" verticalAlignment="center" width="100%">
            <Button
              label="{($item.key || '')}"
              variant="outlined"
              size="sm"
              onClick="sendKeys($item.key + '\r')" />
            <VStack width="*" gap="$space-0_5">
              <Text
                value="{($item.label || '')}"
                fontSize="$fontSize-sm"
                overflowMode="flow"
                breakMode="word" />
              <Text
                when="{$item.description}"
                value="{$item.description}"
                fontSize="$fontSize-xs"
                color="$textColor-secondary"
                overflowMode="flow"
                breakMode="word" />
            </VStack>
          </HStack>
        </Items>
      </Theme>
    </VStack>
    <HStack
      when="{!$props.menu.options || $props.menu.options.length === 0}"
      gap="$space-2"
      wrapContent="true">
      <Button label="1. Yes" variant="outlined" size="sm" onClick="sendKeys('1\r')" />
      <Button label="2. Yes, allow and don't ask again" variant="outlined" size="sm" onClick="sendKeys('2\r')" />
      <Button label="3. No, and tell agent what to do" variant="outlined" size="sm" onClick="sendKeys('3\r')" />
    </HStack>

    <!-- Overflow modal (component-owned so it works on both surfaces). The
         full DiffView here uses its default 60vh virtualized List; a modal is
         allowed its own single scroller. -->
    <Theme maxWidth-ModalDialog="90vw">
      <ModalDialog
        when="{previewModalOpen}"
        onClose="previewModalOpen = false"
        title="{$props.menu.tool}">
        <DiffView
          when="{$props.menu.toolCallDiff}"
          text="{$props.menu.toolCallDiff || ''}" />
        <Markdown
          when="{!$props.menu.toolCallDiff &amp;&amp; $props.menu.toolCallContent}"
          content="{$props.menu.toolCallContent}" />
      </ModalDialog>
    </Theme>
  </VStack>
</Component>

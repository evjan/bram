<Component
  name="Settings"
  var.agentDraft="{''}"
  var.infoTitle="{''}"
  var.infoBody="{''}">

  <DataSource
    id="settingsConfig"
    url="/__settings"
    onLoaded="(v) => agentDraft = settingsAgent(v)" />

  <APICall
    id="saveSettings"
    method="post"
    url="/__settings"
    body="{$param}"
    onSuccess="settingsConfig.refetch()" />

  <VStack
    padding="$space-6"
    gap="$space-5"
    onInit="subscribeTauriEvent('__bramSettingsUnlisten', 'settings-changed', () => settingsConfig.refetch())">

    <Heading level="h2">Settings</Heading>
    <Text
      fontSize="$fontSize-sm"
      color="$textColor-secondary"
      value="Mirrors .bram.json in the project root. Changes save immediately and persist there." />

    <VStack when="{settingsConfig.value}" gap="$space-5">

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Heading level="h3">Shell</Heading>
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Agent command"
            onClick="infoTitle = 'Agent command'; infoBody = 'Typed into the PTY shell at spawn — bash parses it, so flags work (claude --continue, codex resume, etc.). Restart Bram for changes to take effect.'; settingInfoDialog.open()" />
        </HStack>
        <HStack gap="$space-2" verticalAlignment="center">
          <TextBox
            id="agentBox"
            width="*"
            initialValue="{settingsAgent(settingsConfig.value)}"
            onDidChange="(v) => agentDraft = v" />
          <Button
            label="Save"
            enabled="{agentDraft !== settingsAgent(settingsConfig.value) &amp;&amp; agentDraft.trim().length > 0}"
            onClick="saveSettings.execute({ shell: { agent: agentDraft } })" />
        </HStack>
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Heading level="h3">Worklist</Heading>
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Batch commit actions"
            onClick="infoTitle = 'Batch commit actions'; infoBody = 'Adds Approve all / Drop all controls to the Worklist tab when 2 or more TO COMMIT items are present. Approve all authorizes the agent to commit every TO COMMIT item in one turn. Drop all removes them from the worklist (on-disk edits stay).'; settingInfoDialog.open()" />
        </HStack>
        <Switch
          label="Batch commit actions"
          initialValue="{settingsBatch(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ worklist: { batchCommitActions: v } })" />
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Heading level="h3">UI</Heading>
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Minimize target app"
            onClick="infoTitle = 'Minimize target app'; infoBody = 'Drives the agent pane splitter to give the agent tools maximum room. The target app stays mounted at the splitter’s minimum height — distinct from hiding it entirely.'; settingInfoDialog.open()" />
        </HStack>
        <Switch
          label="Minimize target app"
          initialValue="{settingsMinimized(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ ui: { targetAppMinimized: v } })" />
      </VStack>

      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="center">
          <Heading level="h3">Traces</Heading>
          <Button
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About Inspector trace tap"
            onClick="infoTitle = 'Inspector trace tap'; infoBody = 'Forwards XMLUI Inspector events (window._xsLogs) from the agent pane into bram-trace.log as [iframe] subkind=inspector-event, so they interleave with host traces live — no Inspector export needed. Capped at 50 entries per 200ms tick; overflow emits subkind=inspector-overflow. Inspector traces are intentionally complete and noisy (one per keystroke, etc.); future work will add per-category filters.'; settingInfoDialog.open()" />
        </HStack>
        <Switch
          label="Inspector trace tap"
          initialValue="{settingsInspectorTap(settingsConfig.value)}"
          onDidChange="(v) => saveSettings.execute({ traces: { inspectorTap: v } })" />
      </VStack>

    </VStack>

    <Text
      when="{settingsConfig.error}"
      color="$color-danger-700"
      fontSize="$fontSize-sm"
      value="Settings failed to load." />

    <ModalDialog id="settingInfoDialog" title="{infoTitle}">
      <VStack gap="$space-3" padding="$space-2">
        <Text value="{infoBody}" />
        <HStack>
          <Button label="Got it" onClick="settingInfoDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>

  </VStack>
</Component>
